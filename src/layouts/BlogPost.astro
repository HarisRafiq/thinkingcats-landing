---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.blog-hero {
				width: 100%;
				max-width: 900px;
				margin: 0 auto;
				padding: 7rem 1.5rem 2rem;
			}
			.blog-hero img {
				display: block;
				width: 100%;
				border-radius: 14px;
				border: 1px solid rgba(255,255,255,0.06);
			}
			.blog-prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em 4em;
			}
			.blog-title-block {
				margin-bottom: 2em;
				padding-bottom: 2em;
				border-bottom: 1px solid rgba(255,255,255,0.07);
				text-align: center;
			}
			.blog-date {
				font-size: 0.8rem;
				color: rgba(255,255,255,0.3);
				margin-bottom: 0.75rem;
				display: block;
			}
			.blog-title-block h1 {
				font-size: clamp(1.8rem, 4vw, 2.6rem);
				font-weight: 900;
				line-height: 1.15;
				color: #fff;
				letter-spacing: -0.03em;
				margin: 0;
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.78rem;
				color: rgba(255,255,255,0.25);
				margin-top: 0.5rem;
			}
			/* prose content styles */
			.blog-prose :global(p) { color: rgba(255,255,255,0.65); font-size: 1rem; line-height: 1.8; margin-bottom: 1.5em; }
			.blog-prose :global(h2) { font-size: 1.6rem; font-weight: 900; color: #fff; margin: 2em 0 0.6em; letter-spacing: -0.02em; }
			.blog-prose :global(h3) { font-size: 1.25rem; font-weight: 800; color: #fff; margin: 1.75em 0 0.5em; }
			.blog-prose :global(a) { color: #818cf8; text-decoration: underline; text-underline-offset: 2px; }
			.blog-prose :global(a:hover) { color: #a5b4fc; }
			.blog-prose :global(code) { font-size: 0.875em; padding: 2px 6px; background: rgba(255,255,255,0.08); border-radius: 4px; color: rgba(255,255,255,0.8); }
			.blog-prose :global(pre) { padding: 1.5em; border-radius: 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); overflow-x: auto; margin-bottom: 1.5em; }
			.blog-prose :global(pre code) { background: none; padding: 0; }
			.blog-prose :global(blockquote) { border-left: 3px solid #6366f1; padding-left: 1.25em; margin: 1.5em 0; font-style: italic; color: rgba(255,255,255,0.5); }
			.blog-prose :global(hr) { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 2em 0; }
			.blog-prose :global(ul), .blog-prose :global(ol) { color: rgba(255,255,255,0.65); padding-left: 1.5em; margin-bottom: 1.5em; }
			.blog-prose :global(li) { margin-bottom: 0.4em; line-height: 1.7; }
			.blog-prose :global(img) { max-width: 100%; border-radius: 10px; border: 1px solid rgba(255,255,255,0.06); }
			.blog-prose :global(strong) { color: #fff; font-weight: 700; }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="blog-hero">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="blog-prose">
					<div class="blog-title-block">
						<span class="blog-date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="last-updated-on"> · Updated <FormattedDate date={updatedDate} /></span>
							)}
						</span>
						<h1>{title}</h1>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
