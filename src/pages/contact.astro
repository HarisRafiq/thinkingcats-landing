---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact — ${SITE_TITLE}`} description="Have questions or need support? Reach out to the ThinkingCats team." />
	</head>
	<body>
		<Header />
		<main class="compliance-main">
			<div class="compliance-inner">

				<a href="/" class="back-link">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
					<span>Back to Home</span>
				</a>

				<div class="page-header">
					<div class="icon-badge icon-badge--emerald">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon--emerald"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
					</div>
					<div>
						<h1>Contact Us</h1>
						<p class="page-subtitle">Have questions or need support? We're here to help you build your AI brand.</p>
					</div>
				</div>

				<div class="contact-grid">
					<div class="card">
						<div class="icon-badge icon-badge--indigo icon-badge--sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon--indigo"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
						</div>
						<h3>Support Email</h3>
						<p>Our support team usually responds within 24 hours during business days.</p>
						<a href="mailto:support@thinkingcats.com" class="card-link card-link--indigo">support@thinkingcats.com</a>
					</div>

					<div class="card">
						<div class="icon-badge icon-badge--emerald icon-badge--sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon--emerald"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
						</div>
						<h3>Global Access</h3>
						<p>We operate globally and provide 24/7 access to our AI generation services.</p>
						<span class="card-link card-link--emerald">Online 24/7</span>
					</div>
				</div>

				<section class="card card--full dev-card">
					<div class="dev-card-inner">
						<div class="icon-badge icon-badge--violet icon-badge--sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon--violet"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
						</div>
						<div>
							<h3>About the Developer</h3>
							<p>
								<strong>ThinkingCats</strong> is a brain-child of <strong>Haris Rafiq</strong>, inspired by his work at <strong>Bentley Systems</strong> where he worked on digital twins for physical infrastructure. He is now building the same digital-twin concept to the marketing side — creating digital twins that authentically represent brands and grow their online presence. If you have any feature requests or want to chat about AI, digital twins, or anything else, feel free to reach out!
							</p>
							<span class="tag">Infrastructure Digital Twins → Marketing Digital Twins</span>
						</div>
					</div>
				</section>

				<section class="footer-note">
					<p>For legal inquiries, please refer to our <a href="/terms">Terms of Service</a>.</p>
				</section>

			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.compliance-main {
		padding: 8rem 1.5rem 5rem;
	}
	.compliance-inner {
		max-width: 768px;
		margin: 0 auto;
	}
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 13px;
		font-weight: 500;
		color: rgba(255,255,255,0.25);
		text-decoration: none;
		margin-bottom: 3rem;
		transition: color 0.15s;
	}
	.back-link:hover { color: rgba(255,255,255,0.6); }
	.back-link svg { transition: transform 0.15s; }
	.back-link:hover svg { transform: translateX(-3px); }

	.page-header {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 2.5rem;
	}
	.page-header h1 {
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		font-weight: 900;
		letter-spacing: -0.03em;
		color: #fff;
		margin: 0 0 0.25rem;
	}
	.page-subtitle {
		font-size: 0.875rem;
		color: rgba(255,255,255,0.35);
		margin: 0;
	}

	.icon-badge {
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		flex-shrink: 0;
	}
	.icon-badge:not(.icon-badge--sm) { width: 40px; height: 40px; }
	.icon-badge--sm { width: 32px; height: 32px; border-radius: 8px; }
	.icon-badge--emerald { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); }
	.icon-badge--indigo  { background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2); }
	.icon-badge--violet  { background: rgba(139,92,246,0.1); border: 1px solid rgba(139,92,246,0.2); }

	.icon--emerald { color: #34d399; }
	.icon--indigo  { color: #818cf8; }
	.icon--violet  { color: #a78bfa; }

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-bottom: 1rem;
	}
	@media (max-width: 600px) { .contact-grid { grid-template-columns: 1fr; } }

	.card {
		padding: 1.5rem;
		border-radius: 16px;
		background: rgba(255,255,255,0.03);
		border: 1px solid rgba(255,255,255,0.07);
		transition: border-color 0.15s;
	}
	.card:hover { border-color: rgba(255,255,255,0.12); }
	.card--full { margin-top: 1rem; }
	.card h3 {
		font-size: 15px;
		font-weight: 700;
		color: #fff;
		margin: 1rem 0 0.5rem;
	}
	.card p {
		font-size: 14px;
		color: rgba(255,255,255,0.35);
		line-height: 1.6;
		margin: 0 0 1rem;
	}
	.card-link {
		font-size: 14px;
		font-weight: 700;
		text-decoration: none;
	}
	.card-link--indigo { color: #818cf8; }
	.card-link--indigo:hover { text-decoration: underline; }
	.card-link--emerald { color: #34d399; }

	.dev-card-inner {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
	}
	.dev-card-inner .icon-badge { margin-top: 2px; }
	.dev-card-inner h3 {
		font-size: 15px;
		font-weight: 700;
		color: #fff;
		margin: 0 0 0.5rem;
	}
	.dev-card-inner p {
		font-size: 14px;
		color: rgba(255,255,255,0.4);
		line-height: 1.65;
		margin: 0 0 0.75rem;
	}
	.dev-card-inner strong { color: rgba(255,255,255,0.7); }

	.tag {
		display: inline-flex;
		align-items: center;
		padding: 4px 10px;
		border-radius: 8px;
		background: rgba(255,255,255,0.04);
		border: 1px solid rgba(255,255,255,0.07);
		font-size: 11px;
		color: rgba(255,255,255,0.4);
		font-weight: 500;
	}

	.footer-note {
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(255,255,255,0.05);
		text-align: center;
	}
	.footer-note p {
		font-size: 12px;
		color: rgba(255,255,255,0.2);
		margin: 0;
	}
	.footer-note a {
		color: rgba(255,255,255,0.4);
		text-decoration: underline;
	}
	.footer-note a:hover { color: #fff; }
</style>
