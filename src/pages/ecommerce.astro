---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
const description = 'ThinkingCats for ECommerce — AI-powered product descriptions, collection stories, email campaigns, and social content. Scale your content with your catalog.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} for ECommerce`} description={description} />
	</head>
	<body>
		<Header />

		<!-- ── HERO ── -->
		<section class="hero-section">
			<div class="hero-glow" aria-hidden="true"></div>
			<div class="hero-inner">
				<div class="hero-left">
					<div class="hero-badge">
						<svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
						Built for ECommerce
					</div>

					<h1 class="hero-h1">
						<span class="hero-white">Turn your product catalog<br />into a content engine —</span><br />
						<span class="hero-gradient">at scale.</span>
					</h1>

					<p class="hero-sub">
						ThinkingCats writes product descriptions, collection stories, email campaigns, and social content — for <strong>$29/month instead of $15K/month agencies</strong>. One brief, every channel.
					</p>

					<div class="hero-cta">
						<a href="/pricing" class="btn-primary">
							Try it free — no credit card
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</div>

					<div class="hero-trust">
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Product descriptions in 30 seconds</div>
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Launch campaigns from one brief</div>
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>From $29/mo — cancel anytime</div>
					</div>
				</div>

				<div class="hero-right">
					<div class="mockup-card">
						<div class="mockup-titlebar">
							<span class="dot dot-red"></span>
							<span class="dot dot-amber"></span>
							<span class="dot dot-green"></span>
							<span class="mockup-title">ThinkingCats · Director</span>
						</div>
						<div class="mockup-body">
							<div class="mockup-section">
								<p class="label-tiny">Your brief</p>
								<div class="brief-box">Launching our new organic skincare line — 12 products, all clean beauty, vegan, $28–$64 price range.</div>
							</div>
							<div class="status-box">
								<div class="spinner"></div>
								<div>
									<p class="status-title">Analysing product line…</p>
									<p class="status-sub">Scanning market, competitor positioning, trending angles</p>
								</div>
							</div>
							<div class="strategy-box">
								<p class="label-tiny">Proposed strategy</p>
								<p class="strategy-title">Ingredient-led · "What's actually in your skincare — and why it matters"</p>
								<div class="pill-row">
									<span class="pill">Product descriptions</span>
									<span class="pill">Launch email</span>
									<span class="pill">Social carousel</span>
								</div>
							</div>
							<button class="generate-btn">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="zap-icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
								Generate launch content
							</button>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ── COST COMPARISON ── -->
		<section class="cost-bar">
			<div class="cost-grid">
				<div class="cost-item">
					<p class="cost-label">Content agency</p>
					<p class="cost-price cost-red">$5,000–$15,000 / mo</p>
					<p class="cost-note">Retainer, 3-month minimum</p>
				</div>
				<div class="cost-item">
					<p class="cost-label">In-house copywriter</p>
					<p class="cost-price cost-amber">$4,000–$6,000 / mo</p>
					<p class="cost-note">Salary, benefits, management</p>
				</div>
				<div class="cost-item cost-highlight">
					<p class="cost-label">ThinkingCats</p>
					<p class="cost-price cost-green">from $29 / mo</p>
					<p class="cost-note">Unlimited products, cancel anytime</p>
				</div>
			</div>
		</section>

		<!-- ── PAIN ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">The real problem</p>
				<h2 class="section-h2">Your catalog grows faster than your content.</h2>
			</div>
			<div class="pain-grid">
				<div class="pain-card">
					<div class="pain-icon-wrap amber-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
					</div>
					<h3>Hundreds of SKUs, zero time to write</h3>
					<p>Every product needs a description, every collection needs a story, every launch needs a campaign. At 50+ products, the content backlog becomes impossible.</p>
				</div>
				<div class="pain-card">
					<div class="pain-icon-wrap rose-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
					</div>
					<h3>Seasonal campaigns never end</h3>
					<p>Black Friday, Valentine's Day, Summer Drop, Back-to-School — every season needs fresh content. You're always behind on the calendar.</p>
				</div>
				<div class="pain-card">
					<div class="pain-icon-wrap orange-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					</div>
					<h3>Generic AI copy kills conversions</h3>
					<p>You tried ChatGPT — but "luxurious and versatile" product descriptions don't sell. You need copy that understands your brand voice, audience, and product positioning.</p>
				</div>
			</div>
			<p class="pain-tagline">ThinkingCats writes like your best copywriter — at the speed your catalog demands.</p>
		</section>

		<!-- ── WHAT YOU GET ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">Content for every channel</p>
				<h2 class="section-h2">One product brief. Full launch content.</h2>
				<p class="section-sub">Here's what ThinkingCats creates from a single product or collection brief.</p>
			</div>
			<div class="who-grid">
				<div class="who-card">
					<div class="who-icon-wrap amber-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
					</div>
					<div>
						<h3>Product Descriptions</h3>
						<p class="who-subtitle amber-text">Copy that converts, not just describes</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Benefit-led copy, not feature dumps</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Consistent brand voice across your catalog</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>SEO-optimised for product search</li>
					</ul>
				</div>
				<div class="who-card">
					<div class="who-icon-wrap indigo-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
					</div>
					<div>
						<h3>Email Campaigns</h3>
						<p class="who-subtitle indigo-text">Launch, nurture, and win-back flows</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Product launch announcements</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Abandoned cart and win-back sequences</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Seasonal sale campaigns</li>
					</ul>
				</div>
				<div class="who-card">
					<div class="who-icon-wrap purple-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
					</div>
					<div>
						<h3>Social Content</h3>
						<p class="who-subtitle purple-text">Carousels, captions, and stories</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Product showcase carousels</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>UGC-style captions that feel native</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Collection drops and restocks</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- ── HOW IT WORKS ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">How it works</p>
				<h2 class="section-h2">From product to content in 3 steps.</h2>
			</div>

			<div class="steps-list">
				<!-- Step 1 -->
				<div class="step-row">
					<div class="step-text">
						<div class="step-number violet-icon">1</div>
						<h3>Drop in your product details</h3>
						<p>Paste your product name, key features, price, and target customer. ThinkingCats scans competitors, trending angles, and your brand context automatically.</p>
					</div>
					<div class="step-visual">
						<div class="step-mockup">
							<div class="feed-header">
								<div class="feed-dot violet-dot"></div>
								<span>Market Intel</span>
							</div>
							<div class="feed-items">
								<div class="feed-item"><span class="feed-source">Competitor</span><span class="feed-title">Glossier dropped new serum at $34</span></div>
								<div class="feed-item"><span class="feed-source">Trend</span><span class="feed-title">"clean beauty" searches up 28% MoM</span></div>
								<div class="feed-item"><span class="feed-source">Audience</span><span class="feed-title">25–34 F, ingredient-conscious shoppers</span></div>
							</div>
						</div>
					</div>
				</div>

				<!-- Step 2 -->
				<div class="step-row step-row-reverse">
					<div class="step-text">
						<div class="step-number indigo-icon">2</div>
						<h3>Review your launch strategy</h3>
						<p>ThinkingCats proposes the best positioning — ingredient-led, lifestyle, or social proof — plus the content types and channels that match your audience.</p>
					</div>
					<div class="step-visual">
						<div class="step-mockup">
							<div class="feed-header">
								<div class="feed-dot indigo-dot"></div>
								<span>Launch Strategy</span>
							</div>
							<div class="campaign-ideas">
								<div class="campaign-card"><strong>Ingredient-led angle</strong><br /><span class="campaign-sub">"What's actually in your serum — and what's not"</span></div>
								<div class="campaign-card"><strong>Before/after angle</strong><br /><span class="campaign-sub">"30 days with clean skincare: real results, no filters"</span></div>
							</div>
						</div>
					</div>
				</div>

				<!-- Step 3 -->
				<div class="step-row">
					<div class="step-text">
						<div class="step-number purple-icon">3</div>
						<h3>Get publish-ready content</h3>
						<p>Product descriptions, email sequences, social carousels, blog content — all generated, all on-brand, ready to paste into Shopify, Klaviyo, or wherever you publish.</p>
					</div>
					<div class="step-visual">
						<div class="step-mockup">
							<div class="output-grid">
								<div class="output-card">
									<div class="output-label">Product Page</div>
									<p class="output-preview">Meet your new daily glow. Our Vitamin C Serum delivers clinically-proven brightening…</p>
								</div>
								<div class="output-card">
									<div class="output-label">Launch Email</div>
									<p class="output-preview">Subject: "Your skin has been asking for this"<br />Preview: Finally — clean beauty that…</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ── CONTENT TYPES ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">Content types</p>
				<h2 class="section-h2">Every content type an ecommerce brand needs.</h2>
			</div>
			<div class="types-grid">
				<div class="type-card">
					<div class="type-icon amber-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></div>
					<h4>Product Description</h4>
					<p>Benefit-led copy that converts browsers into buyers.</p>
				</div>
				<div class="type-card">
					<div class="type-icon indigo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg></div>
					<h4>Collection Story</h4>
					<p>Narrative copy that ties your collection together with a theme.</p>
				</div>
				<div class="type-card">
					<div class="type-icon purple-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg></div>
					<h4>Email Campaign</h4>
					<p>Launch sequences, sale announcements, and win-back flows.</p>
				</div>
				<div class="type-card">
					<div class="type-icon rose-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg></div>
					<h4>Social Carousel</h4>
					<p>Product showcases, collection drops, and seasonal promos.</p>
				</div>
				<div class="type-card">
					<div class="type-icon emerald-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
					<h4>Blog / SEO Content</h4>
					<p>Buying guides and how-to articles that rank and convert.</p>
				</div>
				<div class="type-card">
					<div class="type-icon orange-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
					<h4>Product Launch</h4>
					<p>Full launch campaigns across email, social, and your site.</p>
				</div>
				<div class="type-card">
					<div class="type-icon violet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg></div>
					<h4>Ad Copy</h4>
					<p>Meta and Google ad copy that stops the scroll and drives clicks.</p>
				</div>
				<div class="type-card">
					<div class="type-icon sky-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
					<h4>Brand Story</h4>
					<p>Your About page, mission statement, and brand narrative.</p>
				</div>
				<div class="type-card">
					<div class="type-icon pink-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
					<h4>Customer Spotlight</h4>
					<p>Turn reviews and UGC into polished social proof content.</p>
				</div>
			</div>
		</section>

		<!-- ── TESTIMONIALS ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">What brands say</p>
				<h2 class="section-h2">ECommerce brands that scaled their content.</h2>
			</div>
			<div class="testimonials-grid">
				<div class="testimonial-card">
					<div class="stars">
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
					</div>
					<p class="testimonial-text">"We had 200 products with generic descriptions. ThinkingCats rewrote them all with benefit-led copy. Our conversion rate went up 18% in the first month."</p>
					<div class="testimonial-metric">
						<span class="metric-value">+18% conversion</span>
						<span class="metric-label">after rewriting product descriptions</span>
					</div>
					<div class="testimonial-author">
						<div class="author-avatar">AK</div>
						<div>
							<p class="author-name">Amanda K.</p>
							<p class="author-role">Founder, Nourish & Bloom (skincare DTC)</p>
						</div>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="stars">
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
					</div>
					<p class="testimonial-text">"We launch 4 collections a year and each one needs a full content suite. ThinkingCats cut our content production time by 80%. Our agency couldn't keep up — this can."</p>
					<div class="testimonial-metric">
						<span class="metric-value">80% faster</span>
						<span class="metric-label">content production per collection</span>
					</div>
					<div class="testimonial-author">
						<div class="author-avatar">JW</div>
						<div>
							<p class="author-name">James W.</p>
							<p class="author-role">Head of Marketing, Trailhead Outdoor Co.</p>
						</div>
					</div>
				</div>
