---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const TIERS = [
	{
		label: "FREE TRIAL",
		price: 0,
		annualPrice: 0,
		brandsLabel: "1 brand",
		posts: 3,
		highlight: false,
		cta: "Try free — no credit card",
		href: "https://ai.thinkingcats.com",
		features: [
			"1 brand",
			"3 posts — full output",
			"Create your first Brand Ambassador",
			"AI logo generation",
			"Director agent",
			"URL reader",
			"Blog + carousel output",
		],
		subtext: "See what consistent, on-brand marketing actually feels like",
	},
	{
		label: "STARTER",
		price: 29,
		annualPrice: 23,
		brandsLabel: "3 brands",
		posts: 30,
		highlight: true,
		badge: "Most Popular",
		cta: "Start for $29/mo",
		href: "https://ai.thinkingcats.com",
		features: [
			"3 brands",
			"30 posts/month",
			"Multiple Brand Ambassadors per brand",
			"AI logo generation",
			"Director — choose your Brand Ambassador per post",
			"URL reader — paste any link",
			"RSS feed monitoring",
			"Campaign + direct creation",
			"Blog + carousel output",
			"50+ languages",
			"Email support",
		],
		subtext: "Less than a single social media ad — for 30 on-brand posts/month",
	},
	{
		label: "PRO",
		price: 99,
		annualPrice: 79,
		brandsLabel: "10 brands",
		posts: 150,
		highlight: false,
		cta: "Get Pro",
		href: "https://ai.thinkingcats.com",
		features: [
			"10 brands",
			"150 posts/month",
			"Multiple Brand Ambassadors per brand",
			"AI logo generation",
			"Director — choose your Brand Ambassador per post",
			"URL reader + RSS monitoring",
			"Campaign + direct creation",
			"Blog + carousel output",
			"Priority generation",
			"Custom visual styles",
			"API access",
			"Priority support",
		],
		subtext: "Full AI content engine — at half the cost of a basic scheduler",
	},
	{
		label: "AGENCY",
		price: 299,
		annualPrice: 239,
		brandsLabel: "Unlimited brands",
		posts: 500,
		highlight: false,
		badge: "Best for agencies",
		cta: "Contact us",
		href: "https://ai.thinkingcats.com",
		features: [
			"Unlimited brands",
			"500 posts/month",
			"Multiple Brand Ambassadors per brand",
			"AI logo generation per brand",
			"Director — choose your Brand Ambassador per post",
			"URL reader + RSS monitoring",
			"White-label output",
			"Custom visual styles per brand",
			"API access",
			"Dedicated account manager",
			"Invoice billing",
			"Priority support",
		],
		subtext: "One plan. Unlimited clients. Scale output without scaling headcount.",
	},
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Pricing — ${SITE_TITLE}`}
			description="Simple, transparent pricing for ThinkingCats. Start free, upgrade when you need more."
		/>
	</head>
	<body>
		<Header />

		<main class="pricing-main">
			<div class="pricing-hero">
				<p class="eyebrow">Simple pricing</p>
				<h1>Your AI Marketing Copilot.<br />All month long, for less than one consulting hour.</h1>
				<div class="founding-badge">Founding member pricing — available while in beta</div>
				<p class="pricing-anchor">
					A marketing consultant charges <span class="cost-red">$150–$300/hr</span>.
					ThinkingCats sets up your brand identity, reads any URL or RSS feed,
					and delivers on-brand content — all month, for less than one hour of consulting.
				</p>
			</div>
		<div class="billing-toggle-wrap">
			<div class="billing-toggle">
				<button class="toggle-btn active" data-billing="annual">Annual</button>
				<button class="toggle-btn" data-billing="monthly">Monthly</button>
			</div>
			<span class="save-chip">Save ~20%</span>
		</div>
			<div class="pricing-grid">
				{TIERS.map(({ label, price, annualPrice, brandsLabel, posts, highlight, badge, cta, href, features, subtext }) => (
					<div class={`pricing-card ${highlight ? 'pricing-highlight' : ''}`}>
						{badge && <div class="pricing-badge">{badge}</div>}
						<div class="pricing-header">
							<p class="pricing-tier-label">{label}</p>
							<div class="pricing-price-row">
							<span class="pricing-price" data-price-monthly={String(price)} data-price-annual={String(annualPrice)}>${annualPrice > 0 ? annualPrice : price}</span>
							{price > 0 && <span class="pricing-per">/mo</span>}
						</div>
						{price > 0 && <p class="pricing-annual" data-note-annual="billed annually" data-note-monthly={`or $${annualPrice}/mo billed annually`}>billed annually</p>}
							<p class="pricing-scope">{brandsLabel} · {posts} posts/mo</p>
							<p class="pricing-subtext">{subtext}</p>
						</div>
						<ul class="pricing-features">
							{features.map((f) => (
								<li>
									<svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
									{f}
								</li>
							))}
						</ul>
						<a
						href={href}
						class={`pricing-cta ${highlight ? 'pricing-cta-highlight' : ''}`}
						data-monthly-cta={cta}
						data-annual-cta={price > 0 && cta.includes('/mo') ? 'Start for $' + annualPrice + '/mo' : cta}>
						{price > 0 && cta.includes('/mo') ? 'Start for $' + annualPrice + '/mo' : cta}
					</a>
					</div>
				))}
			</div>

			<!-- FAQ -->
			<div class="faq-section">
				<h2>Common questions</h2>
				<div class="faq-list" id="faq-list">
					{[
						{ q: "What are Brand Ambassadors?", a: "Brand Ambassadors are visual personas that embody your brand's voice and style — a founder character, a mascot, a spokesperson, whatever fits. Each brand can have multiple. In Director mode, you choose which Brand Ambassador and images to use for each specific post. The result is consistent, visually on-brand content without re-explaining your brand identity every time." },
						{ q: "How does the URL reader work?", a: "Paste any URL — an article, competitor page, product listing, or industry report — and ThinkingCats reads it and extracts the key insights. Your Director agent then works with you to shape the angle and confirm the direction. Once you approve — and pick which Brand Ambassador and images to use — it produces the post in your exact voice. No prompts to write, no copy-pasting." },
						{ q: "What's the RSS feed monitoring for?", a: "Connect any RSS feed — industry news, competitor blogs, trade publications — and ThinkingCats monitors them for you. When something worth reacting to surfaces, your Director agent brings it to you, helps you shape the angle, and only then creates the content. You stay in control; you just never miss a relevant moment." },
						{ q: "Can I cancel anytime?", a: "Yes — cancel whenever you like with no questions asked. No lock-in, no exit fees." },
						{ q: "Is there a trial period?", a: "Yes. The Free Trial gives you 1 brand and 3 full posts — including your first Brand Ambassador, AI logo generation, and full blog + carousel output — with no credit card required." },
						{ q: "Can I manage more than one business?", a: "Yes. Starter supports 3 brands, Pro supports 10, and Agency supports unlimited brands — each with their own multiple Brand Ambassadors, AI-generated logo, and distinct voice." },
						{ q: "What payment methods do you accept?", a: "All major credit cards via Stripe. Invoice billing available on Agency plans." },
						{ q: "How is this different from just using ChatGPT?", a: "ChatGPT is a blank prompt — you have to know what to create, write the brief yourself, and hope the output matches your brand. ThinkingCats gives you a Director agent that reads any source, refines the angle with you, and only creates content once you've approved the direction. Plus your Brand Ambassadors ensure every output sounds like you, not like generic AI." },
					].map(({ q, a }) => (
						<div class="faq-item">
							<button class="faq-q" aria-expanded="false">
								<span>{q}</span>
								<svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
							</button>
							<div class="faq-a" hidden><p>{a}</p></div>
						</div>
					))}
				</div>
			</div>
		</main>

		<Footer />
	</body>
</html>

<script>
	// Billing toggle
	const billingBtns = document.querySelectorAll('.toggle-btn');
	billingBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const billing = (btn as HTMLButtonElement).dataset.billing || 'annual';
			billingBtns.forEach(b => b.classList.toggle('active', (b as HTMLButtonElement).dataset.billing === billing));
			document.querySelectorAll('[data-price-monthly][data-price-annual]').forEach(el => {
				const e = el as HTMLElement;
				e.textContent = '$' + (billing === 'annual' ? e.dataset.priceAnnual : e.dataset.priceMonthly);
			});
			document.querySelectorAll('[data-note-annual][data-note-monthly]').forEach(el => {
				const e = el as HTMLElement;
				e.textContent = billing === 'annual' ? (e.dataset.noteAnnual || '') : (e.dataset.noteMonthly || '');
			});
			document.querySelectorAll('[data-monthly-cta][data-annual-cta]').forEach(el => {
				const e = el as HTMLElement;
				e.textContent = billing === 'annual' ? (e.dataset.annualCta || '') : (e.dataset.monthlyCta || '');
			});
		});
	});

	document.querySelectorAll('.faq-q').forEach((btn) => {
		btn.addEventListener('click', () => {
			const item = btn.parentElement;
			const answer = item?.querySelector('.faq-a') as HTMLElement | null;
			const isOpen = btn.getAttribute('aria-expanded') === 'true';
			document.querySelectorAll('.faq-item').forEach((el) => {
				el.querySelector('.faq-q')?.setAttribute('aria-expanded', 'false');
				const a = el.querySelector('.faq-a') as HTMLElement | null;
				if (a) a.hidden = true;
				el.classList.remove('faq-open');
			});
			if (!isOpen && answer) {
				btn.setAttribute('aria-expanded', 'true');
				answer.hidden = false;
				item?.classList.add('faq-open');
			}
		});
	});
</script>

<style>
	.pricing-main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 8rem 1.5rem 5rem;
	}
	.billing-toggle-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin-bottom: 2rem;
	}
	.billing-toggle {
		display: flex;
		background: rgba(255,255,255,0.05);
		border: 1px solid rgba(255,255,255,0.08);
		border-radius: 100px;
		padding: 4px;
		gap: 2px;
	}
	.toggle-btn {
		padding: 6px 18px;
		border-radius: 100px;
		border: none;
		background: none;
		color: rgba(255,255,255,0.4);
		font-size: 13px;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.15s;
	}
	.toggle-btn.active {
		background: rgba(255,255,255,0.12);
		color: #fff;
	}
	.save-chip {
		font-size: 10px;
		font-weight: 700;
		color: rgba(52,211,153,0.8);
		background: rgba(52,211,153,0.1);
		border: 1px solid rgba(52,211,153,0.2);
		border-radius: 100px;
		padding: 3px 10px;
	}
	.pricing-hero {
		text-align: center;
		margin-bottom: 3rem;
	}
	.eyebrow {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: rgba(129,140,248,0.6);
		margin-bottom: 0.75rem;
	}
	.pricing-hero h1 {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 900;
		letter-spacing: -0.03em;
		line-height: 1.15;
		color: #fff;
		margin-bottom: 1rem;
	}
	.founding-badge {
		display: inline-flex;
		gap: 8px;
		background: rgba(245,158,11,0.1);
		border: 1px solid rgba(245,158,11,0.2);
		border-radius: 100px;
		padding: 6px 16px;
		font-size: 11px;
		font-weight: 700;
		color: rgba(251,191,36,0.7);
		margin-bottom: 1rem;
	}
	.pricing-anchor {
		font-size: 13px;
		color: rgba(255,255,255,0.3);
		margin: 0;
	}
	.cost-red { color: rgba(251,113,133,0.7); font-weight: 700; }

	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.25rem;
		margin-bottom: 5rem;
	}
	@media (max-width: 1024px) { .pricing-grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 600px) { .pricing-grid { grid-template-columns: 1fr; } }

	.pricing-card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 1.75rem;
		background: rgba(255,255,255,0.025);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 16px;
	}
	.pricing-highlight {
		background: rgba(255,255,255,0.05);
		border-color: rgba(99,102,241,0.3);
		box-shadow: 0 0 40px rgba(99,102,241,0.08);
	}
	.pricing-badge {
		position: absolute;
		top: -12px;
		left: 50%;
		transform: translateX(-50%);
		background: linear-gradient(90deg, #6366f1, #a855f7);
		color: #fff;
		font-size: 10px;
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 4px 12px;
		border-radius: 100px;
		box-shadow: 0 0 16px rgba(99,102,241,0.4);
		white-space: nowrap;
	}
	.pricing-header { margin-bottom: 1.5rem; }
	.pricing-tier-label { font-size: 10px; font-weight: 900; color: rgba(255,255,255,0.3); letter-spacing: 0.2em; margin-bottom: 0.75rem; }
	.pricing-price-row { display: flex; align-items: flex-end; gap: 4px; }
	.pricing-price { font-size: 2.5rem; font-weight: 900; letter-spacing: -0.03em; color: #fff; }
	.pricing-per { font-size: 13px; color: rgba(255,255,255,0.25); margin-bottom: 6px; }
	.pricing-annual { font-size: 11px; color: rgba(255,255,255,0.25); margin-top: 4px; }
	.pricing-scope { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 4px; }
	.pricing-subtext { font-size: 11px; color: rgba(255,255,255,0.25); font-style: italic; margin-top: 8px; }
	.pricing-features {
		list-style: none;
		padding: 0;
		margin: 0 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 8px;
		flex: 1;
	}
	.pricing-features li { display: flex; align-items: center; gap: 10px; font-size: 13px; color: rgba(255,255,255,0.5); }
	.check-icon { width: 14px; height: 14px; color: rgba(52,211,153,0.7); flex-shrink: 0; }
	.pricing-cta {
		display: block;
		width: 100%;
		padding: 10px;
		border-radius: 12px;
		font-size: 13px;
		font-weight: 700;
		text-align: center;
		text-decoration: none;
		transition: all 0.15s;
		border: 1px solid rgba(255,255,255,0.08);
		background: rgba(255,255,255,0.06);
		color: #fff;
	}
	.pricing-cta:hover { background: rgba(255,255,255,0.1); color: #fff; }
	.pricing-cta.pricing-cta-highlight {
		background: #4f46e5;
		border-color: transparent;
		box-shadow: 0 0 20px rgba(99,102,241,0.25);
	}
	.pricing-cta.pricing-cta-highlight:hover { background: #6366f1; color: #fff; }

	/* FAQ */
	.faq-section { max-width: 680px; margin: 0 auto; }
	.faq-section h2 { font-size: 1.8rem; font-weight: 900; color: #fff; text-align: center; margin-bottom: 2rem; }
	.faq-list { display: flex; flex-direction: column; gap: 8px; }
	.faq-item {
		border-radius: 12px;
		border: 1px solid rgba(255,255,255,0.06);
		background: rgba(255,255,255,0.015);
		overflow: hidden;
		transition: border-color 0.15s;
	}
	.faq-item:hover { border-color: rgba(255,255,255,0.1); }
	.faq-item.faq-open { border-color: rgba(255,255,255,0.12); background: rgba(255,255,255,0.03); }
	.faq-q {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.25rem;
		background: none;
		border: none;
		cursor: pointer;
		text-align: left;
	}
	.faq-q span { font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.75); }
	.faq-chevron { width: 16px; height: 16px; color: rgba(255,255,255,0.3); flex-shrink: 0; transition: transform 0.2s; }
	.faq-item.faq-open .faq-chevron { transform: rotate(180deg); }
	.faq-a { padding: 0 1.25rem 1.25rem; }
	.faq-a p { font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.7; margin: 0; }
</style>
