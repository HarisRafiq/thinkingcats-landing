---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About — ${SITE_TITLE}`}
			description="ThinkingCats is an AI-powered brand marketing copilot that builds your strategy and writes your content — from one brief."
		/>
	</head>
	<body>
		<Header />
		<main class="about-main">
			<div class="about-hero">
				<p class="eyebrow">About</p>
				<h1>The AI that thinks<br />before it writes.</h1>
				<p class="about-lead">
					ThinkingCats is a brand marketing copilot built for small businesses, consultants, and agencies who need consistent, strategic content — without a full marketing team.
				</p>
			</div>

			<div class="about-body">
				<h2>Our mission</h2>
				<p>
					We believe every business deserves marketing that's grounded in strategy, not guesswork. Most AI writing tools hand you a blank prompt and expect you to already know what to say. ThinkingCats does the thinking first — it monitors your market, proposes a strategy, and then writes the content.
				</p>

				<h2>What we build</h2>
				<ul>
					<li>Market intelligence from RSS feeds and competitor blogs</li>
					<li>AI-generated campaign strategies tailored to your brand</li>
					<li>SEO blog posts and 9-panel social carousels — from one brief</li>
					<li>Support for 50+ languages and multiple brand profiles</li>
				</ul>

				<h2>Get in touch</h2>
				<p>
					Questions, feedback, or partnership enquiries?<br />
					Email us at <a href="mailto:hello@thinkingcats.com">hello@thinkingcats.com</a>.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-main {
		max-width: 768px;
		margin: 0 auto;
		padding: 8rem 1.5rem 5rem;
	}
	.eyebrow {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: rgba(129,140,248,0.6);
		margin-bottom: 0.75rem;
	}
	.about-hero {
		text-align: center;
		margin-bottom: 4rem;
	}
	.about-hero h1 {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 900;
		letter-spacing: -0.03em;
		line-height: 1.1;
		color: #fff;
		margin-bottom: 1.25rem;
	}
	.about-lead {
		font-size: 1.05rem;
		color: rgba(255,255,255,0.4);
		line-height: 1.7;
		max-width: 36rem;
		margin: 0 auto;
	}
	.about-body h2 {
		font-size: 1.25rem;
		font-weight: 800;
		color: #fff;
		margin: 2rem 0 0.75rem;
		letter-spacing: -0.02em;
	}
	.about-body p, .about-body li {
		font-size: 0.95rem;
		color: rgba(255,255,255,0.5);
		line-height: 1.75;
	}
	.about-body ul {
		padding-left: 1.4rem;
		margin-bottom: 1em;
	}
	.about-body li { margin-bottom: 0.4rem; }
	.about-body a { color: #818cf8; }
	.about-body a:hover { color: #a5b4fc; }
</style>

