---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- ══════════════════════════════════════════
		     HERO — Your brand, alive.
		══════════════════════════════════════════ -->
		<section class="hero">
			<div class="hero-grid-overlay" aria-hidden="true"></div>
			<div class="hero-glow" aria-hidden="true"></div>

			<div class="hero-inner">
				<!-- Left: Text -->
				<div class="hero-left">
					<div class="hero-pill">
						<span class="pill-dot"></span>
						AI Brand Activation Platform
					</div>

					<h1 class="hero-h1">
						Your brand,<br />
						<span class="alive-word">alive.</span>
					</h1>

					<p class="hero-p">
						Set up your brand once — AI logo, brand voice, and visual ambassadors included. Then brief your <strong>Director</strong>: paste URLs, attach images, connect an RSS feed, or describe a campaign. It reads everything, shapes the angle with you, and only creates content once you've <em>approved the direction.</em>
					</p>

					<div class="hero-actions">
						<a href="https://ai.thinkingcats.com" class="btn-alive">
							Bring my brand alive
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="btn-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
						<a href="#how-it-works" class="btn-ghost">See how it works</a>
					</div>

					<div class="hero-stats">
						<div class="hstat">
							<span class="hstat-val">10,000+</span>
							<span class="hstat-label">Brands activated</span>
						</div>
						<div class="hstat-div"></div>
						<div class="hstat">
							<span class="hstat-val">4.9 ★</span>
							<span class="hstat-label">Average rating</span>
						</div>
						<div class="hstat-div"></div>
						<div class="hstat">
							<span class="hstat-val">from $23</span>
							<span class="hstat-label">Per month</span>
						</div>
					</div>
				</div>

				<!-- Right: Brand Ambassador + orbiting brand elements -->
				<div class="hero-right">
					<div class="brand-universe">
						<!-- Central: Brand Ambassador portrait placeholder -->
						<div class="ambassador-portrait">
							<div class="portrait-img-placeholder">
								<!-- Replace with real Brand Ambassador image -->
								<div class="portrait-shimmer"></div>
								<div class="portrait-label">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="portrait-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
									Your AI Brand Ambassador
								</div>
							</div>
						</div>

						<!-- Orbiting chips -->
						<div class="orbit-chip chip-logo">
							<div class="chip-logo-mark"></div>
							<span>AI Logo</span>
						</div>
						<div class="orbit-chip chip-voice">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>
							<span>Brand Voice</span>
						</div>
						<div class="orbit-chip chip-director">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
							<span>Director Agent</span>
						</div>
						<div class="orbit-chip chip-carousel">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
							<span>Social carousels</span>
						</div>

						<!-- Floating generated-content card -->
						<div class="float-card">
							<p class="float-card-label">Director ready</p>
							<p class="float-card-title">"5 signs your brand is invisible online"</p>
							<div class="float-card-tags">
								<span class="ftag">Blog</span>
								<span class="ftag">Social carousel</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ══════════════════════════════════════════
		     COST BAR
		══════════════════════════════════════════ -->
		<div class="cost-bar">
			<div class="cost-grid">
				<div class="cost-item">
					<p class="cost-label">Marketing consultant</p>
					<p class="cost-val cost-red">$150–$300 / hr</p>
				</div>
				<div class="cost-item">
					<p class="cost-label">Agency retainer</p>
					<p class="cost-val cost-amber">$2,500–$8,000 / mo</p>
				</div>
				<div class="cost-item cost-highlight">
					<p class="cost-label">ThinkingCats</p>
					<p class="cost-val cost-green">from $29 / mo</p>
					<p class="cost-note">Full platform · cancel anytime</p>
				</div>
			</div>
		</div>

		<!-- ══════════════════════════════════════════
		     POSTS SHOWCASE — Auto-scrolling real output
		══════════════════════════════════════════ -->
		<section class="posts-showcase-section">
			<div class="section-center showcase-header">
				<p class="eyebrow">Real output · generated by ThinkingCats</p>
				<h2 class="section-h2">Content your audience <span class="grad">actually stops for.</span></h2>
				<p class="section-sub">Every post below was created by the Director — on-brand, with a chosen Brand Ambassador, from a brief or URL. No design tool. No copywriter.</p>
			</div>
			<div class="scroll-track-wrap">
				<div class="scroll-track" id="scroll-track">
					{['ex1','ex2','ex3','ex5','ex6','ex7','ex8','ex9'].map((img) => (
						<div class="scroll-slide">
							<img src={`/${img}.png`} alt="Example post generated by ThinkingCats" loading="lazy" />
						</div>
					))}
					{['ex1','ex2','ex3','ex5','ex6','ex7','ex8','ex9'].map((img) => (
						<div class="scroll-slide" aria-hidden="true">
							<img src={`/${img}.png`} alt="" loading="lazy" />
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ══════════════════════════════════════════
		     BRAND IDENTITY — One setup. Three superpowers.
		══════════════════════════════════════════ -->
		<section class="identity-section">
			<div class="section-wrap">
				<div class="section-center">
					<p class="eyebrow">Your brand identity, built by AI</p>
					<h2 class="section-h2">One setup. <span class="grad">Three superpowers.</span></h2>
					<p class="section-sub">Before your Copilot can create content, it needs to know who you are. Set up your brand once — and it never forgets.</p>
				</div>

				<div class="identity-grid">
					<!-- Logo -->
					<div class="id-card">
						<div class="id-visual id-logo-visual">
							<div class="logo-real-demo">
								<div class="lrd-main">
									<img src="/showcase-logo-1.png" alt="AI generated logo variation 1" class="lrd-img-main" loading="lazy" />
								</div>
								<div class="lrd-variants">
									<img src="/showcase-logo-2.png" alt="AI generated logo variation 2" class="lrd-img-variant" loading="lazy" />
									<img src="/showcase-logo-3.png" alt="AI generated logo variation 3" class="lrd-img-variant" loading="lazy" />
								</div>
							</div>
							<p class="id-visual-label">AI generates multiple logo variations from your brand description</p>
						</div>
						<div class="id-text">
							<h3>AI-Generated Logo</h3>
							<p>Upload your own or let ThinkingCats design one. Your logo appears on every blog post and every slide of every social media carousel — forever consistent.</p>
						</div>
					</div>

					<!-- Voice -->
					<div class="id-card">
						<div class="id-visual id-voice-visual">
							<div class="voice-bars">
								{[35, 60, 45, 80, 50, 70, 40, 90, 55, 75, 45, 65].map((h) => (
									<div class="vbar" style={`height: ${h}%`}></div>
								))}
							</div>
							<p class="id-visual-label">Your brand voice, captured and remembered</p>
						</div>
						<div class="id-text">
							<h3>Brand Voice Capture</h3>
							<p>Describe your tone — bold and direct, warm and educational, premium and aspirational. Your Director uses it to shape every brief before a word is written.</p>
						</div>
					</div>

					<!-- Brand Ambassadors -->
					<div class="id-card">
						<div class="id-visual id-ambassador-visual">
							<div class="amb-ss-wrap">
								<img src="/BrandAmbassadorLibrary.png" alt="Brand Ambassador Library interface" class="amb-ss" loading="lazy" />
							</div>
						</div>
						<div class="id-text">
							<h3>Brand Ambassador Library</h3>
							<p>Upload real photos of your team or founder, or create stylised visual personas — a mascot, a spokesperson, an expert character. For each post, you pick which one to feature, so every piece of content feels intentional.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ══════════════════════════════════════════
		     DIRECTOR — Every post is directed first
		══════════════════════════════════════════ -->
		<section class="director-section" id="how-it-works">
			<div class="section-wrap director-layout">
				<!-- Left: Explanation -->
				<div class="director-text">
					<p class="eyebrow">The Director Agent</p>
					<h2 class="director-h2">Every post is <span class="grad">directed</span><br />before it's written.</h2>
					<p class="director-desc">Your Director isn't a prompt box. It reads any source — URLs, images, RSS articles, or a plain-language brief — proposes an angle and format, then works with you to refine it. Iterate in plain language, pick your Brand Ambassador, and only approve once the direction feels right. Nothing is created until you say so.</p>

					<div class="dir-steps">
						<div class="dstep">
							<div class="dstep-num">01</div>
							<div class="dstep-body">
								<strong>Feed it anything</strong>
								<span>Paste up to 5 URLs, attach reference images, connect an RSS feed, or describe a campaign in plain language. Your Director reads and synthesises everything instantly.</span>
							</div>
						</div>
						<div class="dstep">
							<div class="dstep-num">02</div>
							<div class="dstep-body">
								<strong>Shape it together</strong>
								<span>Director proposes an angle, format, and Brand Ambassador. Refine with plain language — as many rounds as you need — until the direction is exactly right.</span>
							</div>
						</div>
						<div class="dstep">
							<div class="dstep-num">03</div>
							<div class="dstep-body">
								<strong>Content ships</strong>
								<span>Only after you approve. Blog post or social carousel — your voice, your logo, and your chosen Brand Ambassador on every slide.</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Right: Director UI mockup -->
				<div class="director-mockup">
					<div class="dmock">
						<div class="dmock-titlebar">
							<span class="ddot ddot-r"></span>
							<span class="ddot ddot-a"></span>
							<span class="ddot ddot-g"></span>
							<span class="dmock-name">ThinkingCats · Director</span>
						</div>
						<div class="dmock-body dmock-body-screenshot">
							<img src="/DirectorExample.png" alt="ThinkingCats Director agent interface" class="director-ss" loading="lazy" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ══════════════════════════════════════════
		     CAMPAIGN PLANNER — Plan a month of content
		══════════════════════════════════════════ -->
		<section class="campaign-section">
			<div class="section-wrap campaign-layout">

				<!-- Left: Mockup -->
				<div class="campaign-mockup-col">
					<div class="cmock">
						<div class="cmock-titlebar">
							<span class="ddot ddot-r"></span>
							<span class="ddot ddot-a"></span>
							<span class="ddot ddot-g"></span>
							<span class="cmock-name">ThinkingCats · Campaign Planner</span>
						</div>
						<div class="cmock-body">

							<div class="cmock-topic-row">
								<p class="dmock-tiny">Campaign topic</p>
								<p class="cmock-brief">"Launching our autumn skincare range"</p>
							</div>

							<p class="dmock-tiny">3 campaign ideas generated</p>

							<div class="cidea">
								<div class="cidea-header">
									<span class="cidea-type cidea-type-mixed">Blog + carousel</span>
									<span class="cidea-angle">Brand story</span>
								</div>
								<p class="cidea-title">Behind the ingredients: what makes our formula different</p>
								<button class="cidea-btn">Send to Director →</button>
							</div>

							<div class="cidea cidea-active">
								<div class="cidea-header">
									<span class="cidea-type cidea-type-social">Social carousel</span>
									<span class="cidea-angle">Educational list</span>
								</div>
								<p class="cidea-title">3 signs your skin needs a fresh autumn routine</p>
								<button class="cidea-btn cidea-btn-selected">Send to Director →</button>
							</div>

							<div class="cidea">
								<div class="cidea-header">
									<span class="cidea-type cidea-type-blog">Blog post</span>
									<span class="cidea-angle">Thought leadership</span>
								</div>
								<p class="cidea-title">Why seasonal skincare switching matters (and what to do instead)</p>
								<button class="cidea-btn">Send to Director →</button>
							</div>

							<button class="cmock-more-btn">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:13px;height:13px"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
								Generate more ideas
							</button>

						</div>
					</div>
				</div>

				<!-- Right: Text -->
				<div class="campaign-text-col">
					<p class="eyebrow">Campaign Planner</p>
					<h2 class="campaign-h2">Plan a full month of content<br /><span class="grad">in one session.</span></h2>
					<p class="campaign-desc">Describe a topic or campaign goal in plain language. ThinkingCats generates a set of distinct ideas — each with a creative angle, a suggested visual style, and the right post type. Pick what fits, refine it, and send any idea straight to Director to create the post. Keep adding ideas any time without starting over.</p>
					<div class="camp-list">
						<div class="camp-item">
							<div class="camp-dot-ind"></div>
							<span>Stop staring at a blank "what should I post?" every week</span>
						</div>
						<div class="camp-item">
							<div class="camp-dot-ind"></div>
							<span>Every idea comes with a suggested angle, visual style, and format</span>
						</div>
						<div class="camp-item">
							<div class="camp-dot-ind"></div>
							<span>Attach up to 3 reference URLs to ground ideas in real content</span>
						</div>
						<div class="camp-item">
							<div class="camp-dot-ind"></div>
							<span>Add more ideas to any campaign without starting over</span>
						</div>
					</div>
				</div>

			</div>
		</section>

		<!-- ══════════════════════════════════════════
		     OUTPUT — What gets created
		══════════════════════════════════════════ -->
		<section class="output-section">
			<div class="section-wrap">
				<div class="section-center">
					<p class="eyebrow">What gets created</p>
					<h2 class="section-h2">Content your audience <span class="grad">stops scrolling for.</span></h2>
					<p class="section-sub">Every output carries your brand — your logo, your Ambassador, your voice. No more generic AI content.</p>
				</div>

				<div class="output-showcase">

					<!-- Social Media Carousel -->
					<div class="output-card output-carousel">
						<div class="oc-badge oc-badge-purple">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
							Social media carousel
						</div>
						<p class="oc-platform">Instagram · LinkedIn · Facebook</p>

						<div class="carousel-demo">
							<!-- Main slide placeholder -->
							<div class="cdemo-main">
								<div class="cdemo-img-placeholder">
									<!-- Replace with real carousel slide image -->
									<div class="cdemo-amb-badge">
										<div class="cdemo-amb-thumb"></div>
										<span>Your Brand Ambassador</span>
									</div>
									<div class="cdemo-overlay">
										<p class="cdemo-headline">5 Signs Your Brand<br />Is Invisible Online</p>
										<div class="cdemo-logo-chip">Your Logo</div>
									</div>
								</div>
							</div>
							<!-- 9-panel thumbnail strip -->
							<div class="cdemo-thumbs">
								{[0,1,2,3,4,5,6,7,8].map((i) => (
									<div class={`cdemo-thumb ${i === 0 ? 'cdemo-thumb-active' : ''}`} style={`background: hsl(${248 + i*12}, 50%, ${9 + i*2}%)`}>
										<span class="cdemo-n">{i+1}</span>
									</div>
								))}
							</div>
						</div>
						<p class="oc-caption">9-panel cinematic carousel — ready to post</p>
					</div>

					<!-- Blog Post -->
					<div class="output-card output-blog">
						<div class="oc-badge oc-badge-emerald">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
							SEO blog post
						</div>
						<p class="oc-platform">Long-form · structured for Google</p>

						<div class="blog-demo">
							<!-- Hero image placeholder -->
							<div class="bdemo-hero">
								<!-- Replace with real blog hero image -->
								<div class="bdemo-amb">
									<div class="bdemo-amb-img"></div>
								</div>
								<div class="bdemo-category">AI Marketing</div>
							</div>
							<div class="bdemo-content">
								<p class="bdemo-read">8 min read</p>
								<h3 class="bdemo-title">What the AI Marketing Wave Means for Your Customers in 2026</h3>
								<div class="bdemo-lines">
									<div class="bline bline-full"></div>
									<div class="bline bline-4-5"></div>
									<div class="bline bline-full"></div>
									<div class="bline bline-3-4"></div>
									<div class="bline bline-full"></div>
								</div>
							</div>
						</div>
						<p class="oc-caption">Full SEO article — no editing needed before publishing</p>
					</div>
				</div>

				<!-- Content types -->
				<div class="content-types">
					<p class="ct-label">Everything your Director can create</p>
					<div class="ct-grid">
						{[
							{ title: "Brand Story", tag: "Blog + carousel" },
							{ title: "Trend Commentary", tag: "Blog + carousel" },
							{ title: "Thought Leadership", tag: "Blog" },
							{ title: "Product Announcement", tag: "Social carousel" },
							{ title: "Educational How-to", tag: "Blog + carousel" },
							{ title: "Case Study", tag: "Blog" },
							{ title: "Promotional Campaign", tag: "Social carousel" },
							{ title: "Advertisement", tag: "Social carousel" },
							{ title: "Market Update", tag: "Blog + carousel" },
						].map(({ title, tag }) => (
							<div class="ct-chip">
								<span class="ct-title">{title}</span>
								<span class="ct-tag">{tag}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- ══════════════════════════════════════════
		     SOURCES — Feed it anything
		══════════════════════════════════════════ -->
		<section class="sources-section">
			<div class="section-wrap sources-layout">
				<div class="sources-text">
					<p class="eyebrow">Powered by any source</p>
					<h2 class="sources-h2">Every source. <span class="grad">One Director.</span></h2>
					<p class="sources-desc">Paste up to 5 URLs, attach reference images, connect RSS feeds, or write a brief in plain language. Whatever you feed your Director, it reads and synthesises everything into an on-brand content brief — before a single word is written.</p>

					<div class="src-list">
						<div class="src-item">
							<div class="src-icon-wrap indigo-icon">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
							</div>
							<div>
								<strong>URL reader</strong>
								<span>Article, competitor page, product listing — paste any link</span>
							</div>
						</div>
						<div class="src-item">
							<div class="src-icon-wrap violet-icon">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
							</div>
							<div>
								<strong>RSS feed monitoring + smart discovery</strong>
								<span>Describe your niche and ThinkingCats suggests which feeds to follow. Spot a trending article and send it to Director in one click — pre-filled and ready to shape.</span>
							</div>
						</div>
						<div class="src-item">
							<div class="src-icon-wrap purple-icon-bg">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
							</div>
							<div>
								<strong>Campaign briefs</strong>
								<span>Describe your goal in plain language — Director builds the strategy</span>
							</div>
						</div>
						<div class="src-item">
							<div class="src-icon-wrap emerald-icon">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
							</div>
							<div>
								<strong>Direct creation</strong>
								<span>Start from a blank idea — Director guides you to the right format and angle</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Live feed mockup -->
				<div class="sources-mockup">
					<div class="feed-mock">
						<div class="feed-mock-header">
							<p class="dmock-tiny">Live industry feed</p>
							<span class="feed-live-dot"></span>
						</div>
						{[
							{ title: "AI adoption in SMBs up 40% — what it means for your clients", src: "TechCrunch", time: "2h ago", hot: true },
