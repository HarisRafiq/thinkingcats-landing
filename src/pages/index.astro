	.indigo-icon { background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.2) !important; color: #818cf8; }
	.violet-icon { background: rgba(139,92,246,0.12); border-color: rgba(139,92,246,0.2) !important; color: #a78bfa; }
	.purple-icon-bg { background: rgba(168,85,247,0.12); border-color: rgba(168,85,247,0.2) !important; color: #c084fc; }
	.emerald-icon { background: rgba(52,211,153,0.12); border-color: rgba(52,211,153,0.2) !important; color: #34d399; }
	.amber-icon { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.2) !important; color: #fbbf24; }

	/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
	   BUTTONS
	━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
	.btn-alive {
		display: inline-flex; align-items: center; gap: 10px;
		padding: 1rem 2rem;
		background: linear-gradient(135deg, #4f46e5, #7c3aed);
		color: #fff; border-radius: 14px; font-weight: 900; font-size: 0.95rem;
		text-decoration: none;
		box-shadow: 0 0 40px rgba(99,102,241,0.4), 0 0 0 1px rgba(99,102,241,0.3);
		transition: box-shadow 0.2s, transform 0.15s;
	}
	.btn-alive:hover {
		box-shadow: 0 0 60px rgba(99,102,241,0.6), 0 0 0 1px rgba(99,102,241,0.5);
		transform: translateY(-1px); color: #fff;
	}
	.btn-alive:active { transform: scale(0.98); }
	.btn-alive-lg { font-size: 1.05rem; padding: 1.1rem 2.5rem; }
	.btn-arrow { width: 18px; height: 18px; transition: transform 0.15s; }
	.btn-alive:hover .btn-arrow { transform: translateX(3px); }
	.btn-ghost {
		display: inline-flex; align-items: center; gap: 8px;
		padding: 1rem 1.5rem; color: var(--text-2); font-weight: 700; font-size: 0.9rem;
		text-decoration: none; border: 1px solid var(--border); border-radius: 14px;
		transition: color 0.15s, border-color 0.15s;
	}
	.btn-ghost:hover { color: var(--text-1); border-color: rgba(255,255,255,0.15); }

	/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
	   HERO
	━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
	.hero {
		position: relative;
		padding: 9rem 1.5rem 6rem;
		overflow: hidden;
	}
	.hero-grid-overlay {
		position: absolute; inset: 0; pointer-events: none;
		background-image:
			linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
		background-size: 60px 60px;
		mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 40%, transparent 100%);
	}
	.hero-glow {
		position: absolute; inset: 0; pointer-events: none;
		background: radial-gradient(ellipse 80% 60% at 60% 20%, rgba(99,102,241,0.15) 0%, transparent 65%);
	}
	.hero-inner {
		position: relative; z-index: 1;
		max-width: 1180px; margin: 0 auto;
		display: grid; grid-template-columns: 1fr 1fr;
		gap: 4rem; align-items: center;
	}
	@media (max-width: 960px) {
		.hero-inner { grid-template-columns: 1fr; }
		.hero-right { order: -1; }
		.hero { padding: 7rem 1.5rem 4rem; }
	}

	/* Hero pill */
	.hero-pill {
		display: inline-flex; align-items: center; gap: 8px;
		background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2);
		border-radius: 100px; padding: 0.4rem 1.1rem;
		font-size: 0.72rem; font-weight: 700; color: rgba(165,180,252,0.8);
		letter-spacing: 0.06em; margin-bottom: 1.75rem;
	}
	.pill-dot {
		width: 6px; height: 6px; border-radius: 50%;
		background: #818cf8;
		box-shadow: 0 0 8px #818cf8;
		animation: pulse-dot 2s ease-in-out infinite;
	}
	@keyframes pulse-dot {
		0%, 100% { box-shadow: 0 0 6px #818cf8; }
		50% { box-shadow: 0 0 14px #818cf8, 0 0 4px #c084fc; }
	}

	/* Hero heading */
	.hero-h1 {
		font-size: clamp(3rem, 6vw, 4.75rem);
		font-weight: 900; letter-spacing: -0.04em; line-height: 0.95;
		margin-bottom: 1.5rem; color: var(--text-1);
	}
	.hero-p {
		font-size: 1.05rem; color: var(--text-2); line-height: 1.75; max-width: 28rem;
		margin-bottom: 2rem; font-weight: 400;
	}
	.hero-p strong { color: rgba(255,255,255,0.8); font-weight: 700; }
	.hero-p em { color: rgba(165,180,252,0.8); font-style: normal; }

	/* Hero actions */
	.hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem; }

	/* Hero stats */
	.hero-stats { display: flex; align-items: center; flex-wrap: wrap; gap: 1rem; }
	.hstat { display: flex; flex-direction: column; gap: 2px; }
	.hstat-val { font-size: 1rem; font-weight: 900; color: var(--text-1); }
	.hstat-label { font-size: 11px; color: var(--text-3); }
	.hstat-div { width: 1px; height: 28px; background: var(--border); }

	/* ── Brand universe (hero right) ── */
	.hero-right { display: flex; justify-content: center; align-items: center; }
	.brand-universe {
		position: relative;
		width: min(420px, 100%);
		height: 420px;
	}

	/* Central portrait */
	.ambassador-portrait {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 210px; height: 280px;
	}
	.portrait-img-placeholder {
		width: 100%; height: 100%;
		border-radius: 24px;
		background: linear-gradient(160deg, rgba(99,102,241,0.15), rgba(168,85,247,0.1), rgba(236,72,153,0.08));
		border: 1px solid rgba(99,102,241,0.25);
		display: flex; flex-direction: column;
		align-items: center; justify-content: flex-end;
		padding-bottom: 1rem;
		overflow: hidden;
		position: relative;
		box-shadow: 0 0 60px rgba(99,102,241,0.15), 0 0 0 1px rgba(99,102,241,0.2);
	}
	.portrait-shimmer {
		position: absolute; inset: 0;
		background: linear-gradient(160deg,
			rgba(99,102,241,0.06) 0%,
			rgba(168,85,247,0.08) 40%,
			rgba(236,72,153,0.06) 70%,
			transparent 100%);
	}
	.portrait-label {
		position: relative; z-index: 1;
		display: flex; align-items: center; gap: 6px;
		font-size: 10px; font-weight: 700; color: rgba(165,180,252,0.7);
		background: rgba(0,0,0,0.4); border: 1px solid rgba(99,102,241,0.2);
		border-radius: 100px; padding: 4px 10px;
	}
	.portrait-icon { width: 12px; height: 12px; }

	/* Orbiting chips */
	.orbit-chip {
		position: absolute;
		display: flex; align-items: center; gap: 6px;
		background: rgba(10,10,20,0.85); border: 1px solid var(--border);
		border-radius: 100px; padding: 6px 12px;
		font-size: 11px; font-weight: 700; color: var(--text-2);
		backdrop-filter: blur(8px);
		white-space: nowrap;
	}
	.chip-icon { width: 13px; height: 13px; }
	.chip-logo { top: 30px; left: 10px; animation: float-up 4s ease-in-out infinite; }
	.chip-logo .chip-logo-mark { width: 14px; height: 14px; border-radius: 4px; background: linear-gradient(135deg, #6366f1, #a855f7); }
	.chip-voice { top: 60px; right: 0; animation: float-up 4s ease-in-out infinite 1s; color: rgba(167,139,250,0.8); border-color: rgba(139,92,246,0.2); }
	.chip-director { bottom: 60px; left: 0; animation: float-up 4s ease-in-out infinite 0.5s; color: rgba(52,211,153,0.8); border-color: rgba(52,211,153,0.2); }
	.chip-carousel { bottom: 30px; right: 5px; animation: float-up 4s ease-in-out infinite 1.5s; color: rgba(251,191,36,0.8); border-color: rgba(245,158,11,0.2); }

	/* Floating card */
	.float-card {
		position: absolute;
		top: 8px; right: -20px;
		background: rgba(10,10,20,0.9); border: 1px solid rgba(99,102,241,0.2);
		border-radius: 14px; padding: 12px 14px;
		backdrop-filter: blur(12px);
		box-shadow: 0 8px 32px rgba(0,0,0,0.4);
		animation: float-up 5s ease-in-out infinite 2s;
		min-width: 170px;
	}
	.float-card-label { font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(52,211,153,0.7); margin-bottom: 5px; }
	.float-card-title { font-size: 11px; font-weight: 700; color: var(--text-1); line-height: 1.4; margin-bottom: 8px; }
	.float-card-tags { display: flex; gap: 4px; flex-wrap: wrap; }
	.ftag { font-size: 9px; font-weight: 700; color: rgba(165,180,252,0.7); background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; padding: 2px 7px; }

	@media (max-width: 960px) {
		.brand-universe { height: 340px; width: 340px; }
		.float-card { right: -5px; }
		.chip-logo { top: 20px; left: 0; }
		.chip-voice { top: 40px; right: 5px; }
	}

	/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
	   COST BAR
	━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
	.cost-bar {
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		padding: 2rem 1.5rem;
		background: rgba(255,255,255,0.01);
	}
	.cost-grid {
		max-width: 900px; margin: 0 auto;
		display: grid; grid-template-columns: repeat(3, 1fr);
		gap: 1rem; text-align: center;
	}
	@media (max-width: 600px) { .cost-grid { grid-template-columns: 1fr; } }
	.cost-item {
		padding: 1.25rem; border-radius: 14px;
		background: var(--surface); border: 1px solid var(--border);
	}
	.cost-item.cost-highlight { background: rgba(52,211,153,0.05); border-color: rgba(52,211,153,0.2); }
	.cost-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-3); margin-bottom: 6px; }
	.cost-val { font-size: 1.4rem; font-weight: 900; letter-spacing: -0.02em; }
	.cost-red { color: rgba(251,113,133,0.8); }
	.cost-amber { color: rgba(251,191,36,0.8); }
	.cost-green { color: var(--emerald); }
	.cost-note { font-size: 11px; color: var(--text-3); margin-top: 4px; }

	/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
	   BRAND IDENTITY
	━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
	.identity-section { background: rgba(255,255,255,0.005); border-bottom: 1px solid var(--border); }
	.identity-grid {
		display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
	}
	@media (max-width: 900px) { .identity-grid { grid-template-columns: 1fr; } }

	.id-card {
		background: var(--surface); border: 1px solid var(--border);
		border-radius: 20px; overflow: hidden;
		display: flex; flex-direction: column;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.id-card:hover { border-color: rgba(99,102,241,0.2); box-shadow: 0 0 40px rgba(99,102,241,0.06); }

	/* Card visual area */
	.id-visual {
		padding: 2rem;
		display: flex; flex-direction: column; align-items: center; gap: 12px;
		min-height: 180px; justify-content: center;
	}
	.id-logo-visual { background: linear-gradient(160deg, rgba(99,102,241,0.08), transparent); }
	.id-voice-visual { background: linear-gradient(160deg, rgba(139,92,246,0.08), transparent); }
	.id-ambassador-visual { background: linear-gradient(160deg, rgba(236,72,153,0.06), rgba(168,85,247,0.06), transparent); }
	.id-visual-label { font-size: 10px; color: var(--text-3); font-weight: 600; text-align: center; }

	/* Logo gen demo */
	.logo-gen-demo { display: flex; align-items: center; gap: 12px; }
	.lgd-main { width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, #4f46e5, #7c3aed); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 20px rgba(99,102,241,0.4); }
	.lgd-shape { width: 28px; height: 28px; background: rgba(255,255,255,0.9); border-radius: 6px; transform: rotate(12deg); }
	.lgd-variants { display: flex; flex-direction: column; gap: 6px; }
	.lgd-v { height: 16px; border-radius: 5px; border: 1px solid var(--border); }
	.lgd-v1 { width: 40px; background: rgba(99,102,241,0.15); }
	.lgd-v2 { width: 36px; background: rgba(168,85,247,0.15); }
	.lgd-v3 { width: 44px; background: rgba(52,211,153,0.1); }

	/* Voice bars */
	.voice-bars { display: flex; align-items: flex-end; gap: 3px; height: 60px; }
	.vbar { width: 6px; border-radius: 3px; background: linear-gradient(to top, #6366f1, #a855f7); min-height: 6px; animation: voice-pulse 2.5s ease-in-out infinite; }
	.vbar:nth-child(even) { animation-delay: 0.3s; }
	.vbar:nth-child(3n) { animation-delay: 0.6s; }
	@keyframes voice-pulse {
		0%, 100% { opacity: 0.6; }
		50% { opacity: 1; }
	}

	/* Ambassador trio */
	.amb-trio { display: flex; align-items: flex-end; gap: 8px; }
	.amb-fig { display: flex; flex-direction: column; align-items: center; gap: 6px; font-size: 10px; color: var(--text-3); font-weight: 600; }
	.amb-fig-center { transform: translateY(-10px); }
	.amb-fig-img {
		width: 48px; height: 64px; border-radius: 12px;
		background: linear-gradient(160deg, rgba(99,102,241,0.2), rgba(168,85,247,0.15));
		border: 1px solid rgba(99,102,241,0.2);
	}
	.amb-fig-img-2 { background: linear-gradient(160deg, rgba(236,72,153,0.2), rgba(168,85,247,0.15)); border-color: rgba(236,72,153,0.2); }
	.amb-fig-img-3 { background: linear-gradient(160deg, rgba(52,211,153,0.15), rgba(99,102,241,0.15)); border-color: rgba(52,211,153,0.2); }
	.amb-fig-center .amb-fig-img { width: 56px; height: 72px; }

	/* Card text */
	.id-text { padding: 1.5rem; border-top: 1px solid var(--border); }
	.id-text h3 { font-size: 15px; font-weight: 900; letter-spacing: -0.01em; margin-bottom: 8px; }
	.id-text p { font-size: 13px; color: var(--text-2); line-height: 1.65; margin: 0; }

	/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
	   DIRECTOR
	━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
	.director-section { border-bottom: 1px solid var(--border); }
	.director-layout {
		display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
	}
	@media (max-width: 900px) { .director-layout { grid-template-columns: 1fr; } }

	.director-h2 {
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 900; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 1rem;
	}
	.director-desc { font-size: 0.9rem; color: var(--text-2); line-height: 1.75; margin-bottom: 2rem; }

	.dir-steps { display: flex; flex-direction: column; gap: 1.25rem; }
	.dstep { display: flex; gap: 1rem; align-items: flex-start; }
	.dstep-num {
		width: 36px; height: 36px; flex-shrink: 0;
		border-radius: 10px; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);
		display: flex; align-items: center; justify-content: center;
		font-size: 11px; font-weight: 900; color: rgba(165,180,252,0.8);
	}
	.dstep-body { display: flex; flex-direction: column; gap: 3px; }
	.dstep-body strong { font-size: 14px; font-weight: 900; color: var(--text-1); }
	.dstep-body span { font-size: 13px; color: var(--text-2); line-height: 1.5; }

	/* Director mockup */
	.dmock {
		background: rgba(255,255,255,0.025);
		border: 1px solid rgba(255,255,255,0.08);
		border-radius: 18px; overflow: hidden;
		box-shadow: 0 0 60px rgba(99,102,241,0.08);
	}
	.dmock-titlebar {
		display: flex; align-items: center; gap: 6px;
		padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.06);
	}
	.ddot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
	.ddot-r { background: rgba(239,68,68,0.5); }
	.ddot-a { background: rgba(245,158,11,0.5); }
	.ddot-g { background: rgba(52,211,153,0.5); }
	.dmock-name { margin-left: 8px; font-size: 11px; font-weight: 700; color: var(--text-3); }
	.dmock-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
	.dmock-row {}
	.dmock-tiny {
		font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em;
		color: var(--text-3); margin-bottom: 6px;
	}
	.dmock-url {
		display: flex; align-items: center; gap: 8px;
		background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
		border-radius: 8px; padding: 9px 12px;
		font-size: 12px; color: var(--text-2);
	}
	.url-icon { width: 13px; height: 13px; flex-shrink: 0; color: rgba(165,180,252,0.6); }
	.dmock-status {
		display: flex; align-items: center; gap: 10px;
		padding: 10px 12px;
		background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.18);
		border-radius: 10px;
	}
	.dmock-spinner {
		width: 16px; height: 16px; flex-shrink: 0;
		border: 2px solid rgba(129,140,248,0.3);
		border-top-color: #818cf8;
		border-radius: 50%;
		animation: spin 1s linear infinite;
	}
	.dmock-status-title { font-size: 11px; font-weight: 900; color: #a5b4fc; }
	.dmock-status-sub { font-size: 10px; color: var(--text-3); margin-top: 1px; }
	.dmock-proposal {
		background: rgba(255,255,255,0.02); border: 1px solid var(--border);
		border-radius: 10px; padding: 12px;
	}
	.dmock-angle { font-size: 12px; font-weight: 900; color: rgba(255,255,255,0.8); margin: 6px 0 8px; }
	.dmock-tags { display: flex; flex-wrap: wrap; gap: 6px; }
	.dtag {
		font-size: 10px; font-weight: 700; border-radius: 100px; padding: 3px 9px;
	}
	.dtag-purple { color: rgba(192,132,252,0.8); background: rgba(168,85,247,0.1); border: 1px solid rgba(168,85,247,0.2); }
	.dmock-amb-row {}
	.dmock-ambs { display: flex; gap: 8px; margin-top: 6px; }
	.damb {
		display: flex; flex-direction: column; align-items: center; gap: 4px;
		font-size: 10px; color: var(--text-3); font-weight: 600;
		padding: 8px; border-radius: 10px; border: 1px solid var(--border);
		background: rgba(255,255,255,0.02);
		cursor: pointer; transition: border-color 0.15s;
		flex: 1;
	}
	.damb-selected { border-color: rgba(99,102,241,0.4); background: rgba(99,102,241,0.08); }
	.damb-img { width: 36px; height: 48px; border-radius: 8px; background: linear-gradient(160deg, rgba(99,102,241,0.25), rgba(168,85,247,0.2)); }
	.damb-img-2 { background: linear-gradient(160deg, rgba(236,72,153,0.2), rgba(168,85,247,0.2)); }
	.damb-img-3 { background: linear-gradient(160deg, rgba(52,211,153,0.15), rgba(99,102,241,0.2)); }
	.dmock-generate {
		width: 100%; padding: 11px; border: none;
		background: linear-gradient(135deg, #4f46e5, #7c3aed);
		border-radius: 10px; color: #fff; font-size: 13px; font-weight: 900;
		cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
		box-shadow: 0 0 20px rgba(99,102,241,0.3);
