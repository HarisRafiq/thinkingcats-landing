---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- ── HERO ── -->
		<section class="hero-section">
			<!-- radial glow -->
			<div class="hero-glow" aria-hidden="true"></div>

			<div class="hero-inner">
				<!-- Left -->
				<div class="hero-left">
					<div class="hero-badge">
						<svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l1.88 5.78L20 9l-4.64 3.37L16.76 18 12 14.77 7.24 18l1.4-5.63L4 9l6.12-.22L12 3z"/></svg>
						Brand Marketing Copilot
					</div>

					<h1 class="hero-h1">
						<span class="hero-white">The AI that builds<br />your strategy —</span><br />
						<span class="hero-gradient">then writes the content.</span>
					</h1>

					<p class="hero-sub">
						ThinkingCats replaces your Jasper, Buffer, and marketing agency — for $29/month. Get <strong>market intelligence, a campaign strategy, and publish-ready content</strong> — from one brief.
					</p>

					<div class="hero-cta">
						<a href="/pricing" class="btn-primary">
							Try it free — no credit card
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</div>

					<div class="hero-trust">
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Replaces your $200/hr consultant</div>
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Blog + carousel from one brief</div>
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>From $29/mo — cancel anytime</div>
					</div>
				</div>

				<!-- Right: Director mockup -->
				<div class="hero-right">
					<div class="mockup-card">
						<div class="mockup-titlebar">
							<span class="dot dot-red"></span>
							<span class="dot dot-amber"></span>
							<span class="dot dot-green"></span>
							<span class="mockup-title">ThinkingCats · Director</span>
						</div>
						<div class="mockup-body">
							<div class="mockup-section">
								<p class="label-tiny">Your brief</p>
								<div class="brief-box">We just launched a new accounting service for local restaurants.</div>
							</div>
							<div class="status-box">
								<div class="spinner"></div>
								<div>
									<p class="status-title">Analysing brief…</p>
									<p class="status-sub">Reading context, classifying post type, extracting facts</p>
								</div>
							</div>
							<div class="strategy-box">
								<p class="label-tiny">Proposed strategy</p>
								<p class="strategy-title">Educational · "5 ways restaurants bleed revenue without realising"</p>
								<div class="pill-row">
									<span class="pill">Blog post</span>
									<span class="pill">Social carousel</span>
									<span class="pill">Data-driven angle</span>
								</div>
							</div>
							<button class="generate-btn">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="zap-icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
								Generate blog + carousel
							</button>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ── COST COMPARISON ── -->
		<section class="cost-bar">
			<div class="cost-grid">
				<div class="cost-item">
					<p class="cost-label">Marketing consultant</p>
					<p class="cost-price cost-red">$150–$300 / hr</p>
					<p class="cost-note">One meeting budget</p>
				</div>
				<div class="cost-item">
					<p class="cost-label">Agency retainer</p>
					<p class="cost-price cost-amber">$2,500–$8,000 / mo</p>
					<p class="cost-note">Per month, minimum</p>
				</div>
				<div class="cost-item cost-highlight">
					<p class="cost-label">ThinkingCats</p>
					<p class="cost-price cost-green">from $29 / mo</p>
					<p class="cost-note">Full platform, cancel anytime</p>
				</div>
			</div>
		</section>

		<!-- ── PAIN ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">The real problem</p>
				<h2 class="section-h2">Why marketing never gets done.</h2>
			</div>
			<div class="pain-grid">
				<div class="pain-card">
					<div class="pain-icon-wrap amber-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
					</div>
					<h3>You're the owner AND the marketer</h3>
					<p>Between operations, sales, and customer service, marketing is always the last thing to get done — and the first to be abandoned.</p>
				</div>
				<div class="pain-card">
					<div class="pain-icon-wrap rose-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
					</div>
					<h3>You don't know which channel to bet on</h3>
					<p>Blog? Instagram? LinkedIn? Google Ads? Without a strategy, you spend money and time on random channels and see no measurable return.</p>
				</div>
				<div class="pain-card">
					<div class="pain-icon-wrap orange-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					</div>
					<h3>You pay for 6 tools and still get no results</h3>
					<p>Canva, Buffer, Jasper, Surfer, Mailchimp — the average SMB spends $200–$300/month on tools but has no strategy to connect them.</p>
				</div>
			</div>
			<p class="pain-tagline">ThinkingCats solves all three — strategy first, content second.</p>
		</section>

		<!-- ── WHO IT'S FOR ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">Who it's for</p>
				<h2 class="section-h2">Built for people who wear too many hats.</h2>
				<p class="section-sub">Pick the profile that sounds like you.</p>
			</div>
			<div class="who-grid">
				<div class="who-card">
					<div class="who-icon-wrap amber-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					</div>
					<div>
						<h3>SMB Owner-Operators</h3>
						<p class="who-subtitle amber-text">You run the business AND the marketing</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>No dedicated marketing team</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Need to stay visible on social + Google</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Want 30 posts/month without 30 hours/month</li>
					</ul>
				</div>
				<div class="who-card">
					<div class="who-icon-wrap indigo-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
					</div>
					<div>
						<h3>B2B Consultants &amp; Founders</h3>
						<p class="who-subtitle indigo-text">You need thought leadership without writing full-time</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Need to publish on LinkedIn consistently</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Want to look like a full marketing team — solo</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Clients come from inbound, not cold outreach</li>
					</ul>
				</div>
				<div class="who-card">
					<div class="who-icon-wrap purple-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
					</div>
					<div>
						<h3>Small Agencies</h3>
						<p class="who-subtitle purple-text">You manage 3–10 client brands and need to scale output</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Manage multiple client brands from one place</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Deliver consistent content without more headcount</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>White-label or resell AI content to clients</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- ── VS COMPARISON ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">Why it's different</p>
				<h2 class="section-h2">Content tools write. ThinkingCats thinks.</h2>
				<p class="section-sub">Jasper, Copy.ai, and Buffer give you a blank prompt and generate text. That still leaves the hard part — knowing what to create — to you.</p>
			</div>
			<div class="compare-table">
				<div class="compare-header">
					<div class="compare-col-feat"></div>
					<div class="compare-col-tools">
						<p class="compare-col-title">AI writing tools</p>
						<p class="compare-col-sub">Jasper · Copy.ai · Buffer AI</p>
					</div>
					<div class="compare-col-tc">
						<p class="compare-col-title tc-title">ThinkingCats</p>
						<p class="compare-col-sub tc-sub">Brand Marketing Copilot</p>
					</div>
				</div>
				{[
					{ feature: "Tells you what to create", tools: false, tc: true },
					{ feature: "Monitors your market", tools: false, tc: true },
					{ feature: "Builds a content strategy", tools: false, tc: true },
					{ feature: "Writes content", tools: true, tc: true },
					{ feature: "Generates social carousels", tools: false, tc: true },
					{ feature: "Produces SEO blog posts", tools: false, tc: true },
					{ feature: "Knows your brand voice", tools: "partial", tc: true },
					{ feature: "Refines briefs with you", tools: false, tc: true },
					{ feature: "Works in 50+ languages", tools: false, tc: true },
				].map(({ feature, tools, tc }) => (
					<div class="compare-row">
						<div class="compare-feat">{feature}</div>
						<div class="compare-val-tools">
							{tools === true ? (
								<svg class="check-sm white30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
							) : tools === "partial" ? (
								<span class="badge-limited">Limited</span>
							) : (
								<svg class="x-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
							)}
						</div>
						<div class="compare-val-tc">
							{tc ? (
								<svg class="check-sm emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
							) : (
								<svg class="x-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
							)}
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- ── HOW IT WORKS ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">How it works</p>
				<h2 class="section-h2">Intelligence → Strategy → Execution.</h2>
				<p class="section-sub">Your full marketing agency — strategy, content, and execution — done in minutes, not weeks.</p>
			</div>

			<!-- Step 1: Intelligence -->
			<div class="hiw-row">
				<div class="hiw-text">
					<div class="hiw-step-header">
						<div class="hiw-icon violet-icon">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-md"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
						</div>
						<span class="step-num">STEP 01</span>
					</div>
					<h3>Intelligence</h3>
					<p class="hiw-tagline violet-text">Know your market before you create</p>
					<p class="hiw-desc">Connect competitor blogs, industry news, and niche RSS feeds. ThinkingCats reads them daily and surfaces what's actually trending in your market — so you're never guessing.</p>
					<div class="pill-row">
						<span class="pill">Competitor monitoring</span>
						<span class="pill">Industry RSS feeds</span>
						<span class="pill">Trend surfacing</span>
					</div>
				</div>
				<div class="hiw-mockup violet-mockup">
					<div class="feed-card">
						<p class="label-tiny">Industry feed</p>
						<div class="feed-item">
							<div class="feed-dot"></div>
							<div class="feed-content">
								<p class="feed-title">AI adoption in SMB services up 40% in Q1</p>
								<p class="feed-meta">TechCrunch · 2h ago</p>
							</div>
							<span class="trending-badge">Trending</span>
						</div>
						<div class="feed-item">
							<div class="feed-dot"></div>
							<div class="feed-content">
								<p class="feed-title">Google updates local business ranking factors</p>
								<p class="feed-meta">Search Engine Journal · 5h ago</p>
							</div>
						</div>
						<div class="feed-item">
							<div class="feed-dot"></div>
							<div class="feed-content">
								<p class="feed-title">Why B2B blogs outperform paid ads in 2026</p>
								<p class="feed-meta">HubSpot Blog · 1d ago</p>
							</div>
						</div>
						<button class="feed-cta">Create post from article →</button>
					</div>
				</div>
			</div>

			<!-- Step 2: Strategy -->
			<div class="hiw-row hiw-row-reverse">
				<div class="hiw-text">
					<div class="hiw-step-header">
						<div class="hiw-icon indigo-icon">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-md"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
						</div>
						<span class="step-num">STEP 02</span>
					</div>
					<h3>Strategy</h3>
					<p class="hiw-tagline indigo-text">A plan, not just a prompt</p>
					<p class="hiw-desc">Tell ThinkingCats your goal or topic. It generates a full campaign — multiple content angles, the right format for each piece, and a clear brief — built around your brand voice.</p>
					<div class="pill-row">
						<span class="pill">Campaign angles</span>
						<span class="pill">Format selection</span>
						<span class="pill">Brand voice alignment</span>
					</div>
				</div>
				<div class="hiw-mockup indigo-mockup hiw-mockup-first">
					<div class="strategy-mock">
						<p class="label-tiny">Campaign ideas</p>
						<p class="strategy-topic">Topic: "Why local service businesses lose leads online"</p>
						<div class="idea-list">
							<div class="idea-item">
								<p class="idea-title">The $5K mistake local businesses make every month</p>
								<div class="pill-row">
									<span class="pill-indigo">Educational · Data-driven</span>
									<span class="pill">Blog post</span>
								</div>
							</div>
							<div class="idea-item">
								<p class="idea-title">3 signs your Google listing is costing you jobs</p>
								<div class="pill-row">
									<span class="pill-indigo">How-to · Actionable</span>
									<span class="pill">Carousel</span>
								</div>
							</div>
							<div class="idea-item">
								<p class="idea-title">We audited 100 local business websites. Here's what we found.</p>
								<div class="pill-row">
									<span class="pill-indigo">Case study · Proof</span>
									<span class="pill">Carousel</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Step 3: Execution -->
			<div class="hiw-row">
				<div class="hiw-text">
					<div class="hiw-step-header">
						<div class="hiw-icon purple-icon">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-md"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
						</div>
						<span class="step-num">STEP 03</span>
					</div>
					<h3>Execution</h3>
					<p class="hiw-tagline purple-text">Publish-ready content, every time</p>
					<p class="hiw-desc">Approve the strategy. ThinkingCats produces a full blog post for SEO or a cinematic 9-panel social carousel — with your brand's unique visual identity on every piece.</p>
					<div class="pill-row">
						<span class="pill">Blog posts</span>
						<span class="pill">9-panel carousels</span>
						<span class="pill">Your brand on every post</span>
					</div>
				</div>
				<div class="hiw-mockup purple-mockup">
					<div class="output-grid">
						<div class="output-item">
							<div class="output-header">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="output-icon emerald-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
								<span class="output-type">Blog Post</span>
							</div>
							<div class="skeleton-lines">
								<div class="sk-line sk-full"></div>
								<div class="sk-line sk-4-5"></div>
								<div class="sk-line sk-full"></div>
								<div class="sk-line sk-3-4"></div>
								<div class="sk-line sk-full"></div>
							</div>
							<p class="output-tag emerald-tag">SEO-optimised · Long-form</p>
						</div>
						<div class="output-item">
							<div class="output-header">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="output-icon purple-icon-sm"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
								<span class="output-type">9-Panel Grid</span>
							</div>
							<div class="carousel-grid">
								{[0,1,2,3,4,5,6,7,8].map((i) => (
									<div class="carousel-cell" style={`background: hsl(${240 + i * 15}, 70%, ${15 + i * 2}%)`}></div>
								))}
							</div>
							<p class="output-tag purple-tag">Cinematic · Carousel-ready</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ── STATS ── -->
		<section class="stats-bar">
			<div class="stats-inner">
				<div class="stat-item"><span class="stat-val">10,000+</span><span class="stat-label">Brands created</span></div>
				<div class="stat-item"><span class="stat-val">50+</span><span class="stat-label">Languages</span></div>
				<div class="stat-item"><span class="stat-val">9</span><span class="stat-label">Content formats</span></div>
				<div class="stat-item"><span class="stat-val">4.9 / 5</span><span class="stat-label">Avg. rating</span></div>
			</div>
		</section>

		<!-- ── CONTENT TYPES ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">What you can create</p>
				<h2 class="section-h2">Every format your business needs.</h2>
				<p class="section-sub">Describe your goal. ThinkingCats automatically picks the right format and executes it.</p>
			</div>
			<div class="content-type-grid">
				{[
					{ title: "Advertisement", desc: "Product promos and offer launches" },
					{ title: "Brand Story", desc: "Founder journey, origins, culture" },
					{ title: "Product Announcement", desc: "New launches and feature reveals" },
					{ title: "Educational", desc: "How-tos your audience bookmarks" },
					{ title: "Trend Commentary", desc: "React to news from your brand's POV" },
					{ title: "Thought Leadership", desc: "Opinions that position you as the expert" },
					{ title: "How-to Guide", desc: "Step-by-step content that drives saves" },
					{ title: "Case Study", desc: "Proof that builds trust with buyers" },
					{ title: "Promotional", desc: "Seasonal campaigns and sales" },
				].map(({ title, desc }) => (
					<div class="ct-card">
