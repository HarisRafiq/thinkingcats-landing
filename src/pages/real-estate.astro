				const a = b.parentElement?.querySelector('.faq-a');
				if (a instanceof HTMLElement) a.style.maxHeight = '0';
			});
			if (!isOpen && answer instanceof HTMLElement) {
				btn.setAttribute('aria-expanded', 'true');
				item?.classList.add('faq-open');
				answer.style.maxHeight = answer.scrollHeight + 'px';
			}
		});
	});
</script>
