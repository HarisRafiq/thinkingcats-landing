---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
const description = 'ThinkingCats for Real Estate — AI-powered listing descriptions, neighborhood guides, and social content. Stop writing, start closing.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} for Real Estate`} description={description} />
	</head>
	<body>
		<Header />

		<!-- ── HERO ── -->
		<section class="hero-section">
			<div class="hero-glow" aria-hidden="true"></div>
			<div class="hero-inner">
				<div class="hero-left">
					<div class="hero-badge">
						<svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
						Built for Real Estate
					</div>

					<h1 class="hero-h1">
						<span class="hero-white">Turn every listing into<br />a content machine —</span><br />
						<span class="hero-gradient">while you focus on closing.</span>
					</h1>

					<p class="hero-sub">
						ThinkingCats writes your listing descriptions, neighborhood guides, open house posts, and market updates — for <strong>$29/month instead of $100/listing</strong>. One brief, all channels.
					</p>

					<div class="hero-cta">
						<a href="https://ai.thinkingcats.com" class="btn-primary">
							Try it free — no credit card
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</div>

					<div class="hero-trust">
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Listing descriptions in 60 seconds</div>
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Blog + social from one brief</div>
						<div class="trust-item"><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>From $29/mo — cancel anytime</div>
					</div>
				</div>

				<div class="hero-right">
					<div class="mockup-card">
						<div class="mockup-titlebar">
							<span class="dot dot-red"></span>
							<span class="dot dot-amber"></span>
							<span class="dot dot-green"></span>
							<span class="mockup-title">ThinkingCats · Director</span>
						</div>
						<div class="mockup-body">
							<div class="mockup-section">
								<p class="label-tiny">Your brief</p>
								<div class="brief-box">Just listed a 4-bed colonial in Westfield, NJ — $725K, renovated kitchen, walkable to downtown.</div>
							</div>
							<div class="status-box">
								<div class="spinner"></div>
								<div>
									<p class="status-title">Analysing listing…</p>
									<p class="status-sub">Pulling comps, neighbourhood data, buyer persona</p>
								</div>
							</div>
							<div class="strategy-box">
								<p class="label-tiny">Proposed strategy</p>
								<p class="strategy-title">Lifestyle · "Your morning walk to downtown Westfield starts here"</p>
								<div class="pill-row">
									<span class="pill">Listing description</span>
									<span class="pill">Social carousel</span>
									<span class="pill">Neighbourhood guide</span>
								</div>
							</div>
							<button class="generate-btn">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="zap-icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
								Generate listing content
							</button>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ── COST COMPARISON ── -->
		<section class="cost-bar">
			<div class="cost-grid">
				<div class="cost-item">
					<p class="cost-label">Real estate copywriter</p>
					<p class="cost-price cost-red">$75–$150 / listing</p>
					<p class="cost-note">Per listing, every time</p>
				</div>
				<div class="cost-item">
					<p class="cost-label">Marketing assistant</p>
					<p class="cost-price cost-amber">$3,000–$5,000 / mo</p>
					<p class="cost-note">Salary, benefits, training</p>
				</div>
				<div class="cost-item cost-highlight">
					<p class="cost-label">ThinkingCats</p>
					<p class="cost-price cost-green">from $29 / mo</p>
					<p class="cost-note">Unlimited listings, cancel anytime</p>
				</div>
			</div>
		</section>

		<!-- ── PAIN ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">The real problem</p>
				<h2 class="section-h2">You're an agent, not a content creator.</h2>
			</div>
			<div class="pain-grid">
				<div class="pain-card">
					<div class="pain-icon-wrap amber-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
					</div>
					<h3>Every listing needs unique content</h3>
					<p>MLS descriptions, Instagram posts, Facebook ads, neighbourhood blogs — and every listing needs its own. That's hours per property you don't have.</p>
				</div>
				<div class="pain-card">
					<div class="pain-icon-wrap rose-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
					</div>
					<h3>Your time is worth $200+/hour</h3>
					<p>Every hour spent writing a listing description is an hour you're not prospecting, showing homes, or negotiating offers. The math doesn't work.</p>
				</div>
				<div class="pain-card">
					<div class="pain-icon-wrap orange-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					</div>
					<h3>Top producers out-content you</h3>
					<p>The agents winning your market post daily — listing tours, market reports, neighbourhood spotlights. Without content, you're invisible to future sellers.</p>
				</div>
			</div>
			<p class="pain-tagline">ThinkingCats turns one listing brief into a full content engine.</p>
		</section>

		<!-- ── WHAT YOU GET ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">Content for every channel</p>
				<h2 class="section-h2">One listing brief. Six pieces of content.</h2>
				<p class="section-sub">Here's what ThinkingCats creates from a single property brief.</p>
			</div>
			<div class="who-grid">
				<div class="who-card">
					<div class="who-icon-wrap amber-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
					</div>
					<div>
						<h3>Listing Descriptions</h3>
						<p class="who-subtitle amber-text">MLS-ready in 60 seconds</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Compelling, unique descriptions — not templates</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Highlights lifestyle, not just square footage</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Adjusts tone for luxury, starter, investment</li>
					</ul>
				</div>
				<div class="who-card">
					<div class="who-icon-wrap indigo-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
					</div>
					<div>
						<h3>Social Carousels</h3>
						<p class="who-subtitle indigo-text">Instagram & Facebook ready</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Swipeable listing tours and market stats</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Open house announcements that get saves</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>"Just sold" and "just listed" templates</li>
					</ul>
				</div>
				<div class="who-card">
					<div class="who-icon-wrap purple-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
					</div>
					<div>
						<h3>Neighbourhood Guides</h3>
						<p class="who-subtitle purple-text">Position yourself as the local expert</p>
					</div>
					<ul class="who-list">
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>SEO-optimised blog posts for your farm area</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Schools, dining, lifestyle — auto-researched</li>
						<li><svg class="check-icon emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Rank on Google for "[your town] real estate"</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- ── HOW IT WORKS ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">How it works</p>
				<h2 class="section-h2">From listing to content in 3 steps.</h2>
			</div>

			<div class="steps-list">
				<!-- Step 1 -->
				<div class="step-row">
					<div class="step-text">
						<div class="step-number violet-icon">1</div>
						<h3>Drop in your listing details</h3>
						<p>Paste the address, price, and key features. ThinkingCats pulls neighbourhood data, school ratings, and local market trends automatically.</p>
					</div>
					<div class="step-visual">
						<div class="step-mockup">
							<div class="feed-header">
								<div class="feed-dot violet-dot"></div>
								<span>Property Intel</span>
							</div>
							<div class="feed-items">
								<div class="feed-item"><span class="feed-source">Zillow</span><span class="feed-title">Westfield median: $685K (+4.2% YoY)</span></div>
								<div class="feed-item"><span class="feed-source">Schools</span><span class="feed-title">Franklin Elementary — 9/10 rating</span></div>
								<div class="feed-item"><span class="feed-source">Walk Score</span><span class="feed-title">Downtown: 82/100 — Very Walkable</span></div>
							</div>
						</div>
					</div>
				</div>

				<!-- Step 2 -->
				<div class="step-row step-row-reverse">
					<div class="step-text">
						<div class="step-number indigo-icon">2</div>
						<h3>Review your content strategy</h3>
						<p>ThinkingCats proposes the best angle — lifestyle, investment, or family — plus the right content types for your listing price and buyer persona.</p>
					</div>
					<div class="step-visual">
						<div class="step-mockup">
							<div class="feed-header">
								<div class="feed-dot indigo-dot"></div>
								<span>Strategy</span>
							</div>
							<div class="campaign-ideas">
								<div class="campaign-card"><strong>Lifestyle angle</strong><br /><span class="campaign-sub">"Morning coffee, evening strolls — life in downtown Westfield"</span></div>
								<div class="campaign-card"><strong>Family angle</strong><br /><span class="campaign-sub">"Top-rated schools, big backyard — the family upgrade"</span></div>
							</div>
						</div>
					</div>
				</div>

				<!-- Step 3 -->
				<div class="step-row">
					<div class="step-text">
						<div class="step-number purple-icon">3</div>
						<h3>Get publish-ready content</h3>
						<p>Listing description, social carousel, neighbourhood blog, open house post — all generated, all on-brand, all ready to copy-paste.</p>
					</div>
					<div class="step-visual">
						<div class="step-mockup">
							<div class="output-grid">
								<div class="output-card">
									<div class="output-label">MLS Description</div>
									<p class="output-preview">Nestled on a tree-lined street in downtown Westfield, this beautifully renovated 4-bedroom colonial blends…</p>
								</div>
								<div class="output-card">
									<div class="output-label">Instagram Carousel</div>
									<p class="output-preview">Slide 1: "Your morning walk to downtown starts here"<br />Slide 2: Renovated chef's kitchen…</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ── CONTENT TYPES ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">Content types</p>
				<h2 class="section-h2">Every content type a top agent needs.</h2>
			</div>
			<div class="types-grid">
				<div class="type-card">
					<div class="type-icon amber-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
					<h4>Listing Description</h4>
					<p>MLS-ready copy that sells the lifestyle, not just the specs.</p>
				</div>
				<div class="type-card">
					<div class="type-icon indigo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg></div>
					<h4>Social Carousel</h4>
					<p>Swipeable listing tours, market updates, and open house promos.</p>
				</div>
				<div class="type-card">
					<div class="type-icon purple-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
					<h4>Neighbourhood Guide</h4>
					<p>SEO blog posts about your farm area — schools, dining, lifestyle.</p>
				</div>
				<div class="type-card">
					<div class="type-icon rose-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg></div>
					<h4>Open House Post</h4>
					<p>Eye-catching social announcements that drive foot traffic.</p>
				</div>
				<div class="type-card">
					<div class="type-icon emerald-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
					<h4>Market Update</h4>
					<p>Monthly reports with local data — position yourself as the expert.</p>
				</div>
				<div class="type-card">
					<div class="type-icon orange-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg></div>
					<h4>Email Newsletter</h4>
					<p>Keep your sphere warm with market insights and new listings.</p>
				</div>
				<div class="type-card">
					<div class="type-icon violet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg></div>
					<h4>Video Script</h4>
					<p>Listing tour and neighbourhood walkthrough scripts for Reels and TikTok.</p>
				</div>
				<div class="type-card">
					<div class="type-icon sky-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
					<h4>Buyer Guide</h4>
					<p>First-time buyer content that attracts leads from Google.</p>
				</div>
				<div class="type-card">
					<div class="type-icon pink-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-sm"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
					<h4>Just Sold Story</h4>
					<p>Celebrate wins and build social proof with your network.</p>
				</div>
			</div>
		</section>

		<!-- ── TESTIMONIALS ── -->
		<section class="section-pad">
			<div class="section-center">
				<p class="eyebrow">What agents say</p>
				<h2 class="section-h2">Agents who stopped writing and started closing.</h2>
			</div>
			<div class="testimonials-grid">
				<div class="testimonial-card">
					<div class="stars">
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
					</div>
					<p class="testimonial-text">"I used to spend 45 minutes writing each listing description. Now I paste the details and get better copy in under a minute. Game changer."</p>
					<div class="testimonial-metric">
						<span class="metric-value">45 min → 1 min</span>
						<span class="metric-label">per listing description</span>
					</div>
					<div class="testimonial-author">
						<div class="author-avatar">JR</div>
						<div>
							<p class="author-name">Jessica R.</p>
							<p class="author-role">Keller Williams, Austin TX</p>
						</div>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="stars">
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
					</div>
					<p class="testimonial-text">"The neighbourhood guides rank on Google and bring me inbound leads. I've gotten 3 listing appointments from my blog content this quarter."</p>
					<div class="testimonial-metric">
						<span class="metric-value">3 listings</span>
						<span class="metric-label">from blog content this quarter</span>
					</div>
					<div class="testimonial-author">
						<div class="author-avatar">MT</div>
						<div>
							<p class="author-name">Marcus T.</p>
							<p class="author-role">RE/MAX, Scottsdale AZ</p>
						</div>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="stars">
						<svg viewBox="0 0 24 24" fill="currentColor" class="star"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
