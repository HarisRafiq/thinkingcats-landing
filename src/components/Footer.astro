---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/" class="brand-link">
				<img src="/logo.png" alt="ThinkingCats" class="footer-logo-img" />
			</a>
		</div>
		<nav class="footer-links">
			<a href="/pricing">Pricing</a>
			<a href="/blog">Blog</a>
			<a href="/about">About</a>
			<a href="/rss.xml">RSS</a>
		</nav>
		<p class="footer-copy">&copy; {today.getFullYear()} ThinkingCats</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid rgba(255,255,255,0.05);
		padding: 2.5rem 1.5rem;
	}
	.footer-inner {
		max-width: 1152px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1.5rem;
	}
	.brand-link {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 13px;
		font-weight: 900;
		color: #fff;
		text-decoration: none;
		letter-spacing: -0.01em;
	}
	.brand-link:hover { color: #fff; }
	.footer-logo-img {
		height: 24px;
		width: auto;
		display: block;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 1.25rem;
	}
	.footer-links a {
		font-size: 12px;
		font-weight: 500;
		color: rgba(255,255,255,0.25);
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-links a:hover { color: rgba(255,255,255,0.5); }
	.footer-copy {
		font-size: 12px;
		color: rgba(255,255,255,0.2);
		margin: 0;
	}
</style>

