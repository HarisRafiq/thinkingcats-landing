---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<nav class="site-nav">
		<a href="/" class="site-logo">
			<img src="/logo.png" alt="ThinkingCats" class="site-logo-img" />
		</a>
		<div class="nav-links">
			<a href="/blog" class="nav-link">Blog</a>
			<a href="/pricing" class="nav-link">Pricing</a>
			<a href="/about" class="nav-link nav-link-muted">About</a>
			<a href="https://ai.thinkingcats.com" class="nav-cta">Start for free</a>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		padding: 0 1.5rem;
		background: rgba(8,8,8,0.8);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}
	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1152px;
		margin: 0 auto;
		height: 60px;
	}
	.site-logo {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 15px;
		font-weight: 900;
		color: #fff;
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.site-logo:hover { opacity: 0.85; }
	.site-logo-img {
		height: 28px;
		width: auto;
		display: block;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.nav-link {
		font-size: 13px;
		font-weight: 600;
		color: rgba(255,255,255,0.5);
		text-decoration: none;
		padding: 6px 10px;
		border-radius: 8px;
		transition: color 0.15s;
	}
	.nav-link:hover { color: rgba(255,255,255,0.85); }
	.nav-link-muted { color: rgba(255,255,255,0.35); }
	.nav-cta {
		margin-left: 8px;
		padding: 8px 16px;
		background: #fff;
		color: #000;
		border-radius: 10px;
		font-size: 13px;
		font-weight: 900;
		text-decoration: none;
		transition: background 0.15s;
	}
	.nav-cta:hover { background: rgba(255,255,255,0.9); color: #000; }
	@media (max-width: 600px) {
		.nav-link, .nav-link-muted { display: none; }
	}
</style>
